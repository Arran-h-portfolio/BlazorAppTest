@page "/"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<section class="hero">
    <div class="hero-content">
        <h1>RotaHub</h1>
        <h2>Smarter staff scheduling, without the stress</h2>

        <p class="hero-subtext">
            Automate your staff scheduling with a smarter, faster rota system. Manage your team, set availability, and generate optimised rotas in seconds.
        </p>

        <div class="hero-buttons">
            <button class="btn-primary">Get Started</button>
            <button class="btn-primary">View Demo</button>
        </div>
    </div>
</section>

<section class="features">
    <div class="feature-card">
        <h3>👥 Staff Management</h3>
        <p>Add and organise your team with ease.</p>
    </div>

    <div class="feature-card">
        <h3>🕒 Availability Tracking</h3>
        <p>Prevent conflicts before they happen.</p>
    </div>

    <div class="feature-card">
        <h3>⚡ Auto Rota Generator</h3>
        <p>Create optimised schedules instantly.</p>
    </div>

    <div class="feature-card">
        <h3>✏️ Manual Editing</h3>
        <p>Full control when you need it.</p>
    </div>
</section>
