@page "/dashboard"
@using StaffCost.Models
@using StaffInput.Models
@using ClosedXML.Excel
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject IJSRuntime JS

<PageTitle>Dashboard</PageTitle>

<section class="dashboard dashboard-page">
    <header class="dashboard-header card">
        <div class="dashboard-header-body">
            <div class="dashboard-title-block">
            <h1>Cost Dashboard</h1>
            <p>Live totals based on your saved rota and current staff hourly wages.</p>
                <span class="dashboard-subnote">Review weekly staffing cost, tax uplift, and export-ready payroll data in one place.</span>
            </div>
            <div class="dashboard-actions">
                <div class="date-selector dashboard-control">
                    <label for="rotaDate" class="form-label mb-1">Rota date</label>
                <input id="rotaDate" class="form-control" type="date" @bind="rotaDate" />
                </div>
                <div class="tax-rate-control dashboard-control">
                    <label for="employerTaxRate" class="form-label mb-1">Employer tax (%)</label>
                <input id="employerTaxRate" class="form-control" type="number" min="0" max="100" step="0.1" @bind="employerTaxRatePercent" @bind:after="OnTaxRateChanged" />
                </div>
                <div class="dashboard-button-row">
                    <button class="btn btn-primary" @onclick="RefreshDashboard" disabled="@isLoadingDashboard">Refresh</button>
                    <button class="btn btn-secondary" @onclick="ExportToExcel" disabled="@(isLoadingDashboard || weeklyStaffCost.TotalCost == 0)">Export Excel</button>
                    <button class="btn btn-outline-secondary" @onclick="ShowExportModal" disabled="@(isLoadingDashboard || weeklyStaffCost.TotalCost == 0)">View Export</button>
                </div>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(dashboardStatusMessage))
    {
        <div class="alert alert-info dashboard-status" role="alert">@dashboardStatusMessage</div>
    }

    @if (showExportModal && !string.IsNullOrWhiteSpace(exportedCsvContent))
    {
        <div class="modal-backdrop dashboard-modal-backdrop" @onclick="CloseExportModal"></div>
        <div class="modal-dialog dashboard-modal-dialog">
            <div class="modal-content dashboard-modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Export Data Preview</h5>
                    <button type="button" class="btn-close" @onclick="CloseExportModal"></button>
                </div>
                <div class="modal-body">
                    <textarea class="form-control" style="height: 400px; font-family: monospace; font-size: 11px;" readonly>@exportedCsvContent</textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseExportModal">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="CopyExportToClipboard">Copy to Clipboard</button>
                </div>
            </div>
        </div>
    }

    @if (isLoadingDashboard)
    {
        <p class="text-muted dashboard-loading">Loading dashboard data...</p>
    }
    else
    {
        <div class="dashboard-cards">
            <article class="dashboard-card total">
                <span class="dashboard-card-kicker">Weekly total</span>
                <h2>Total Staff Cost (Week)</h2>
                <p class="mb-1"><strong>Gross:</strong> @FormatCurrency(weeklyStaffCost.TotalCost)</p>
                <p class="big"><strong>After Tax:</strong> @FormatCurrency(GetAfterTaxAmount(weeklyStaffCost.TotalCost))</p>
            </article>
            <article class="dashboard-card">
                <span class="dashboard-card-kicker">Volume</span>
                <h2>Saved Rota Rows</h2>
                <p class="big">@savedRotaRowCount</p>
            </article>
            <article class="dashboard-card">
                <span class="dashboard-card-kicker">Counted</span>
                <h2>Paid Assignments Counted</h2>
                <p class="big">@countedAssignmentRows</p>
            </article>
        </div>

        <div class="dashboard-grid">
            <section class="panel">
                <div class="panel-header">
                    <h3>Total Staff Cost Per Day</h3>
                    <span class="panel-note">Gross vs after-tax view</span>
                </div>
                <table class="table dashboard-table mb-0">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th class="text-end">Gross</th>
                            <th class="text-end">After Tax</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dayTotal in dailyStaffCosts)
                        {
                            <tr>
                                <td>@GetDayName(dayTotal.DayOfWeek)</td>
                                <td class="text-end">@FormatCurrency(dayTotal.TotalCost)</td>
                                <td class="text-end">@FormatCurrency(GetAfterTaxAmount(dayTotal.TotalCost))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>

            <section class="panel">
                <div class="panel-header">
                    <h3>Staff Cost Breakdown</h3>
                    <span class="panel-note">Per employee summary</span>
                </div>
                @if (staffCostBreakdown.Any())
                {
                    <table class="table dashboard-table mb-0">
                        <thead>
                            <tr>
                                <th>Staff</th>
                                <th class="text-end">Gross</th>
                                <th class="text-end">After Tax</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cost in staffCostBreakdown)
                            {
                                <tr>
                                    <td>@cost.EmployeeName</td>
                                    <td class="text-end">@FormatCurrency(cost.TotalCost)</td>
                                    <td class="text-end">@FormatCurrency(GetAfterTaxAmount(cost.TotalCost))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">No paid assignments found in the saved rota.</p>
                }
            </section>
        </div>

        <div class="dashboard-grid chart-grid mt-3">
            <section class="panel">
                <div class="panel-header">
                    <h3>Who Costs More Per Week (Hours Worked)</h3>
                    <span class="panel-note">Share of gross weekly cost</span>
                </div>
                @if (staffCostBreakdown.Any())
                {
                    var staffSlices = GetStaffCostPieSlices();
                    <div class="pie-layout">
                        <div class="pie-visual" style="@BuildPieChartStyle(staffSlices)" role="img" aria-label="Weekly staff cost share"></div>
                        <div class="pie-legend">
                            @foreach (var slice in staffSlices)
                            {
                                <div class="legend-row">
                                    <span class="legend-dot" style="background-color: @slice.Color"></span>
                                    <span class="legend-label">@slice.Label</span>
                                    <span class="legend-value">@FormatCurrency(slice.Amount) (@slice.Percentage.ToString("0.0")%)</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No staff cost data available yet.</p>
                }
            </section>

            <section class="panel">
                <div class="panel-header">
                    <h3>Gross vs Tax Add-On</h3>
                    <span class="panel-note">Employer uplift composition</span>
                </div>
                @if (weeklyStaffCost.TotalCost > 0)
                {
                    var taxSlices = GetTaxCompositionPieSlices();
                    <div class="pie-layout">
                        <div class="pie-visual" style="@BuildPieChartStyle(taxSlices)" role="img" aria-label="Gross and employer tax composition"></div>
                        <div class="pie-legend">
                            @foreach (var slice in taxSlices)
                            {
                                <div class="legend-row">
                                    <span class="legend-dot" style="background-color: @slice.Color"></span>
                                    <span class="legend-label">@slice.Label</span>
                                    <span class="legend-value">@FormatCurrency(slice.Amount) (@slice.Percentage.ToString("0.0")%)</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No weekly gross value available yet.</p>
                }
            </section>
        </div>
    }
</section>

@code {
    private bool isLoadingDashboard = false;
    private string dashboardStatusMessage = string.Empty;
    private int savedRotaRowCount = 0;
    private int countedAssignmentRows = 0;
    private decimal employerTaxRatePercent = 20m;
    private DateOnly rotaDate = new();
    private bool showExportModal = false;
    private string exportedCsvContent = string.Empty;
    private readonly string[] PieChartColors =
    {
        "#ef4444", "#f59e0b", "#10b981", "#3b82f6", "#8b5cf6", "#ec4899", "#14b8a6", "#84cc16"
    };

    private readonly string[] WeekDays = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    private List<TotalStaffCostPerDay> dailyStaffCosts = new();
    private TotalStaffCostPerWeek weeklyStaffCost = new(0);
    private List<StaffCostWithName> staffCostBreakdown = new();

    private sealed class DashboardRotaRow
    {
        public string Day { get; set; } = string.Empty;
        public string EmployeeID { get; set; } = string.Empty;
        public string StaffName { get; set; } = string.Empty;
        public string StartTime { get; set; } = string.Empty;
        public string EndTime { get; set; } = string.Empty;
    }

    private sealed class PieSlice
    {
        public string Label { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public decimal Percentage { get; set; }
        public string Color { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        rotaDate = DateOnly.FromDateTime(DateTime.Now);
        await LoadDashboardData();
    }

    private async Task RefreshDashboard()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        isLoadingDashboard = true;
        dashboardStatusMessage = string.Empty;

        try
        {
            var staffList = await localStorage.GetItemAsync<List<StaffInput>>("stafflist") ?? new List<StaffInput>();
            var savedRows = await localStorage.GetItemAsync<List<DashboardRotaRow>>("generatedRotaRows") ?? new List<DashboardRotaRow>();

            savedRotaRowCount = savedRows.Count;
            countedAssignmentRows = 0;

            var dayTotals = Enumerable.Range(0, 7).ToDictionary(dayIndex => dayIndex, _ => 0m);
            var staffTotals = new Dictionary<string, decimal>();
            var staffLookup = staffList.ToDictionary(staff => staff.EmployeeID, staff => staff);

            foreach (var row in savedRows)
            {
                if (string.IsNullOrWhiteSpace(row.EmployeeID)
                    || row.StaffName == "Unfilled"
                    || row.StaffName == "No staff required")
                {
                    continue;
                }

                if (!TryGetDayIndex(row.Day, out var dayIndex))
                {
                    continue;
                }

                if (!staffLookup.TryGetValue(row.EmployeeID, out var staff) || staff.HourlyWage <= 0)
                {
                    continue;
                }

                if (!TryGetShiftHours(row.StartTime, row.EndTime, out var shiftHours) || shiftHours <= 0)
                {
                    continue;
                }

                var shiftCost = decimal.Round(staff.HourlyWage * (decimal)shiftHours, 2);
                dayTotals[dayIndex] += shiftCost;

                if (!staffTotals.TryAdd(staff.EmployeeID, shiftCost))
                {
                    staffTotals[staff.EmployeeID] += shiftCost;
                }

                countedAssignmentRows++;
            }

            dailyStaffCosts = Enumerable.Range(0, 7)
                .Select(dayIndex => new TotalStaffCostPerDay(dayIndex, decimal.Round(dayTotals[dayIndex], 2)))
                .ToList();

            weeklyStaffCost = new TotalStaffCostPerWeek(decimal.Round(dayTotals.Values.Sum(), 2));

            staffCostBreakdown = staffTotals
                .OrderByDescending(entry => entry.Value)
                .Select(entry =>
                {
                    var staff = staffLookup[entry.Key];
                    return new StaffCostWithName(staff.EmployeeID, decimal.Round(entry.Value, 2), staff.NewStaffName);
                })
                .ToList();

            dashboardStatusMessage = $"Loaded {savedRotaRowCount} saved rota rows. Counted {countedAssignmentRows} paid assignments.";
        }
        catch (Exception ex)
        {
            dashboardStatusMessage = $"Unable to load dashboard data: {ex.Message}";
            dailyStaffCosts = Enumerable.Range(0, 7)
                .Select(dayIndex => new TotalStaffCostPerDay(dayIndex, 0))
                .ToList();
            weeklyStaffCost = new TotalStaffCostPerWeek(0);
            staffCostBreakdown = new List<StaffCostWithName>();
        }
        finally
        {
            isLoadingDashboard = false;
        }
    }

    private static bool TryGetShiftHours(string startTime, string endTime, out double hours)
    {
        hours = 0;

        if (!TimeOnly.TryParse(startTime, out var start) || !TimeOnly.TryParse(endTime, out var end))
        {
            return false;
        }

        var startSpan = start.ToTimeSpan();
        var endSpan = end.ToTimeSpan();
        var duration = endSpan - startSpan;

        if (duration <= TimeSpan.Zero)
        {
            duration = duration.Add(TimeSpan.FromDays(1));
        }

        hours = duration.TotalHours;
        return true;
    }

    private Task OnTaxRateChanged()
    {
        employerTaxRatePercent = Math.Clamp(employerTaxRatePercent, 0m, 100m);
        return Task.CompletedTask;
    }

    private decimal GetAfterTaxAmount(decimal grossAmount)
    {
        var taxRate = Math.Clamp(employerTaxRatePercent, 0m, 100m) / 100m;
        var afterTaxAmount = grossAmount * (1 + taxRate);
        return decimal.Round(afterTaxAmount, 2);
    }

    private List<PieSlice> GetStaffCostPieSlices()
    {
        var total = staffCostBreakdown.Sum(x => x.TotalCost);
        if (total <= 0)
        {
            return new List<PieSlice>();
        }

        return staffCostBreakdown
            .Select((cost, index) => new PieSlice
            {
                Label = cost.EmployeeName,
                Amount = cost.TotalCost,
                Percentage = decimal.Round((cost.TotalCost / total) * 100m, 1),
                Color = PieChartColors[index % PieChartColors.Length]
            })
            .ToList();
    }

    private List<PieSlice> GetTaxCompositionPieSlices()
    {
        var gross = weeklyStaffCost.TotalCost;
        var afterTax = GetAfterTaxAmount(gross);
        var taxPortion = Math.Max(0, decimal.Round(afterTax - gross, 2));
        var total = gross + taxPortion;

        if (total <= 0)
        {
            return new List<PieSlice>();
        }

        var slices = new List<PieSlice>
        {
            new()
            {
                Label = "Gross",
                Amount = gross,
                Percentage = decimal.Round((gross / total) * 100m, 1),
                Color = "#3b82f6"
            }
        };

        if (taxPortion > 0)
        {
            slices.Add(new PieSlice
            {
                Label = "Tax Add-On",
                Amount = taxPortion,
                Percentage = decimal.Round((taxPortion / total) * 100m, 1),
                Color = "#f97316"
            });
        }

        return slices;
    }

    private static string BuildPieChartStyle(List<PieSlice> slices)
    {
        if (!slices.Any())
        {
            return "background: conic-gradient(#e2e8f0 0% 100%);";
        }

        var gradientStops = new List<string>();
        decimal currentStart = 0m;

        foreach (var slice in slices)
        {
            var currentEnd = Math.Min(100m, currentStart + slice.Percentage);
            gradientStops.Add($"{slice.Color} {currentStart.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}% {currentEnd.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}%");
            currentStart = currentEnd;
        }

        if (currentStart < 100m)
        {
            gradientStops.Add($"#e2e8f0 {currentStart.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}% 100%");
        }

        return $"background: conic-gradient({string.Join(", ", gradientStops)});";
    }

    private bool TryGetDayIndex(string? day, out int dayIndex)
    {
        dayIndex = Array.FindIndex(WeekDays, weekDay => string.Equals(weekDay, day, StringComparison.OrdinalIgnoreCase));
        return dayIndex >= 0;
    }

    private string GetDayName(int dayIndex)
    {
        return dayIndex >= 0 && dayIndex < WeekDays.Length ? WeekDays[dayIndex] : "Unknown";
    }

    private static string FormatCurrency(decimal amount)
    {
        return $"£{amount:0.00}";
    }

    private async Task ExportToExcel()
    {
        try
        {
            dashboardStatusMessage = "Generating Excel export...";
            StateHasChanged();
            
            var staffList = await localStorage.GetItemAsync<List<StaffInput>>("stafflist") ?? new List<StaffInput>();
            var savedRows = await localStorage.GetItemAsync<List<DashboardRotaRow>>("generatedRotaRows") ?? new List<DashboardRotaRow>();

            var excelBytes = GenerateExcelFile(staffList, savedRows);
            var fileName = $"rota_export_{rotaDate:yyyy-MM-dd}.xlsx";
            
            await SaveExportFileToDisk(excelBytes, fileName);
        }
        catch (Exception ex)
        {
            dashboardStatusMessage = $"Export failed: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"Export error: {ex}");
        }
    }

    private string GenerateCsvContent(List<StaffInput> staffList, List<DashboardRotaRow> rotaRows)
    {
        var builder = new System.Text.StringBuilder();

        builder.AppendLine("Section,Metric,Value");
        builder.AppendLine($"Summary,Export Date,{EscapeCsv(rotaDate.ToString("yyyy-MM-dd"))}");
        builder.AppendLine($"Summary,Exported At,{EscapeCsv(DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"))}");
        builder.AppendLine($"Summary,Employer Tax Percent,{employerTaxRatePercent:0.##}%");
        builder.AppendLine($"Summary,Weekly Gross Cost,{FormatCurrency(weeklyStaffCost.TotalCost)}");
        builder.AppendLine($"Summary,Weekly After Tax Cost,{FormatCurrency(GetAfterTaxAmount(weeklyStaffCost.TotalCost))}");
        builder.AppendLine($"Summary,Tax Add-On,{FormatCurrency(GetAfterTaxAmount(weeklyStaffCost.TotalCost) - weeklyStaffCost.TotalCost)}");
        builder.AppendLine($"Summary,Saved Rota Rows,{savedRotaRowCount}");
        builder.AppendLine($"Summary,Counted Assignments,{countedAssignmentRows}");

        builder.AppendLine();
        builder.AppendLine("Daily Costs");
        builder.AppendLine("Day,Gross,After Tax");
        foreach (var day in dailyStaffCosts)
        {
            builder.AppendLine($"{EscapeCsv(GetDayName(day.DayOfWeek))},{EscapeCsv(FormatCurrency(day.TotalCost))},{EscapeCsv(FormatCurrency(GetAfterTaxAmount(day.TotalCost)))}");
        }

        builder.AppendLine();
        builder.AppendLine("Staff Breakdown");
        builder.AppendLine("Employee ID,Employee Name,Gross,After Tax");
        foreach (var staff in staffCostBreakdown)
        {
            builder.AppendLine($"{EscapeCsv(staff.EmployeeID)},{EscapeCsv(staff.EmployeeName)},{EscapeCsv(FormatCurrency(staff.TotalCost))},{EscapeCsv(FormatCurrency(GetAfterTaxAmount(staff.TotalCost)))}");
        }

        builder.AppendLine();
        builder.AppendLine("Rota Details");
        builder.AppendLine("Day,Staff ID,Staff Name,Start Time,End Time");
        foreach (var row in rotaRows.Where(row => !string.IsNullOrWhiteSpace(row.EmployeeID)
            && row.StaffName != "Unfilled"
            && row.StaffName != "No staff required"))
        {
            builder.AppendLine($"{EscapeCsv(row.Day)},{EscapeCsv(row.EmployeeID)},{EscapeCsv(row.StaffName)},{EscapeCsv(row.StartTime)},{EscapeCsv(row.EndTime)}");
        }

        return builder.ToString();
    }

    private byte[] GenerateExcelFile(List<StaffInput> staffList, List<DashboardRotaRow> rotaRows)
    {
        using var workbook = new XLWorkbook();

        var summarySheet = workbook.Worksheets.Add("Summary");
        summarySheet.Cell(1, 1).Value = "Metric";
        summarySheet.Cell(1, 2).Value = "Value";
        summarySheet.Cell(2, 1).Value = "Export Date";
        summarySheet.Cell(2, 2).Value = rotaDate.ToString("yyyy-MM-dd");
        summarySheet.Cell(3, 1).Value = "Exported At";
        summarySheet.Cell(3, 2).Value = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
        summarySheet.Cell(4, 1).Value = "Employer Tax Percent";
        summarySheet.Cell(4, 2).Value = employerTaxRatePercent / 100m;
        summarySheet.Cell(4, 2).Style.NumberFormat.Format = "0.00%";
        summarySheet.Cell(5, 1).Value = "Weekly Gross Cost";
        summarySheet.Cell(5, 2).Value = weeklyStaffCost.TotalCost;
        summarySheet.Cell(6, 1).Value = "Weekly After Tax Cost";
        summarySheet.Cell(6, 2).Value = GetAfterTaxAmount(weeklyStaffCost.TotalCost);
        summarySheet.Cell(7, 1).Value = "Tax Add-On";
        summarySheet.Cell(7, 2).Value = GetAfterTaxAmount(weeklyStaffCost.TotalCost) - weeklyStaffCost.TotalCost;
        summarySheet.Cell(8, 1).Value = "Saved Rota Rows";
        summarySheet.Cell(8, 2).Value = savedRotaRowCount;
        summarySheet.Cell(9, 1).Value = "Counted Assignments";
        summarySheet.Cell(9, 2).Value = countedAssignmentRows;

        summarySheet.Range(1, 1, 1, 2).Style.Font.Bold = true;
        summarySheet.Range(5, 2, 7, 2).Style.NumberFormat.Format = "\u00A3#,##0.00";
        summarySheet.Columns().AdjustToContents();

        var dailySheet = workbook.Worksheets.Add("Daily Costs");
        dailySheet.Cell(1, 1).Value = "Day";
        dailySheet.Cell(1, 2).Value = "Gross";
        dailySheet.Cell(1, 3).Value = "After Tax";

        var dailyRow = 2;
        foreach (var day in dailyStaffCosts)
        {
            dailySheet.Cell(dailyRow, 1).Value = GetDayName(day.DayOfWeek);
            dailySheet.Cell(dailyRow, 2).Value = day.TotalCost;
            dailySheet.Cell(dailyRow, 3).Value = GetAfterTaxAmount(day.TotalCost);
            dailyRow++;
        }

        dailySheet.Range(1, 1, 1, 3).Style.Font.Bold = true;
        dailySheet.Range(2, 2, Math.Max(2, dailyRow - 1), 3).Style.NumberFormat.Format = "\u00A3#,##0.00";
        dailySheet.Columns().AdjustToContents();

        var staffSheet = workbook.Worksheets.Add("Staff Breakdown");
        staffSheet.Cell(1, 1).Value = "Employee ID";
        staffSheet.Cell(1, 2).Value = "Employee Name";
        staffSheet.Cell(1, 3).Value = "Gross";
        staffSheet.Cell(1, 4).Value = "After Tax";

        var staffRow = 2;
        foreach (var staff in staffCostBreakdown)
        {
            staffSheet.Cell(staffRow, 1).Value = staff.EmployeeID;
            staffSheet.Cell(staffRow, 2).Value = staff.EmployeeName;
            staffSheet.Cell(staffRow, 3).Value = staff.TotalCost;
            staffSheet.Cell(staffRow, 4).Value = GetAfterTaxAmount(staff.TotalCost);
            staffRow++;
        }

        staffSheet.Range(1, 1, 1, 4).Style.Font.Bold = true;
        staffSheet.Range(2, 3, Math.Max(2, staffRow - 1), 4).Style.NumberFormat.Format = "\u00A3#,##0.00";
        staffSheet.Columns().AdjustToContents();

        var rotaSheet = workbook.Worksheets.Add("Rota Details");
        rotaSheet.Cell(1, 1).Value = "Day";
        rotaSheet.Cell(1, 2).Value = "Staff ID";
        rotaSheet.Cell(1, 3).Value = "Staff Name";
        rotaSheet.Cell(1, 4).Value = "Start Time";
        rotaSheet.Cell(1, 5).Value = "End Time";

        var rotaRow = 2;
        foreach (var row in rotaRows.Where(row => !string.IsNullOrWhiteSpace(row.EmployeeID)
            && row.StaffName != "Unfilled"
            && row.StaffName != "No staff required"))
        {
            rotaSheet.Cell(rotaRow, 1).Value = row.Day;
            rotaSheet.Cell(rotaRow, 2).Value = row.EmployeeID;
            rotaSheet.Cell(rotaRow, 3).Value = row.StaffName;
            rotaSheet.Cell(rotaRow, 4).Value = row.StartTime;
            rotaSheet.Cell(rotaRow, 5).Value = row.EndTime;
            rotaRow++;
        }

        rotaSheet.Range(1, 1, 1, 5).Style.Font.Bold = true;
        rotaSheet.Columns().AdjustToContents();

        using var stream = new MemoryStream();
        workbook.SaveAs(stream);
        return stream.ToArray();
    }

    private async Task SaveExportFileToDisk(byte[] content, string fileName)
    {
        try
        {
            // Try to save to Documents folder first, fall back to Desktop
            string? destinationPath = null;
            
            var documentsPath = Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
            if (!string.IsNullOrEmpty(documentsPath) && Directory.Exists(documentsPath))
            {
                destinationPath = Path.Combine(documentsPath, fileName);
            }
            else
            {
                var desktopPath = Environment.GetFolderPath(Environment.SpecialFolder.Desktop);
                if (!string.IsNullOrEmpty(desktopPath) && Directory.Exists(desktopPath))
                {
                    destinationPath = Path.Combine(desktopPath, fileName);
                }
            }

            if (string.IsNullOrEmpty(destinationPath))
            {
                // Fallback to current directory if neither works
                destinationPath = Path.Combine(AppContext.BaseDirectory, fileName);
            }

            // Write the file
            await File.WriteAllBytesAsync(destinationPath, content);
            
            dashboardStatusMessage = $"✓ Export saved successfully to: {destinationPath}";
            System.Diagnostics.Debug.WriteLine($"Export saved to: {destinationPath}");
        }
        catch (Exception ex)
        {
            dashboardStatusMessage = $"Failed to save file: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"File save error: {ex}");
            throw;
        }
    }

    private async Task ShowExportModal()
    {
        try
        {
            var staffList = await localStorage.GetItemAsync<List<StaffInput>>("stafflist") ?? new List<StaffInput>();
            var savedRows = await localStorage.GetItemAsync<List<DashboardRotaRow>>("generatedRotaRows") ?? new List<DashboardRotaRow>();
            exportedCsvContent = GenerateCsvContent(staffList, savedRows);
            showExportModal = true;
        }
        catch (Exception ex)
        {
            dashboardStatusMessage = $"Failed to generate export: {ex.Message}";
        }
    }

    private Task CloseExportModal()
    {
        showExportModal = false;
        return Task.CompletedTask;
    }

    private async Task CopyExportToClipboard()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", exportedCsvContent);
            dashboardStatusMessage = "Export copied to clipboard!";
        }
        catch (Exception ex)
        {
            dashboardStatusMessage = $"Failed to copy: {ex.Message}";
        }
    }

    private static string EscapeCsv(string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            return string.Empty;
        }

        var escaped = value.Replace("\"", "\"\"");
        return $"\"{escaped}\"";
    }
}
