@page "/rotaGenerator"
@using DayRequirements.Models
@using StaffInput.Models
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<style>
    @@media print {
        @@page {
            size: A4 landscape;
            margin: 0.35cm;
        }

        html,
        body {
            margin: 0 !important;
            padding: 0 !important;
            font-size: 10px;
        }

        .no-print {
            display: none !important;
        }

        body * {
            visibility: hidden;
        }

        #rotaPrintArea,
        #rotaPrintArea * {
            visibility: visible;
        }

        #rotaPrintArea {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
        }

        #rotaPrintArea .table {
            width: 100% !important;
            table-layout: fixed;
            font-size: 9px;
            margin-bottom: 0;
        }

        #rotaPrintArea th,
        #rotaPrintArea td {
            padding: 0.15rem !important;
            vertical-align: top;
            line-height: 1.15;
            word-break: break-word;
        }

        #rotaPrintArea .fw-semibold {
            font-weight: 600 !important;
        }

        #rotaPrintArea .mb-1 {
            margin-bottom: 0.1rem !important;
        }

        #rotaPrintArea table,
        #rotaPrintArea tr,
        #rotaPrintArea td,
        #rotaPrintArea th {
            page-break-inside: avoid !important;
        }
    }
</style>

<PageTitle>Rota Generator</PageTitle>

<section class="rota-page">
    <header class="rota-header card">
        <div class="rota-header-body">
            <div class="rota-header-copy">
                <h1>Rota Generator</h1>
                <p>Generate a weekly rota using the saved staff list, day requirements, opening times, and job-role rules.</p>
                <span class="rota-subnote">Build, review, edit, and export from one workflow without changing any of your saved logic.</span>
            </div>
            <div class="rota-toolbar no-print">
                <button class="btn btn-primary" @onclick="GenerateRota" disabled="@isLoading">Generate rota</button>
                <button class="btn btn-outline-secondary" @onclick="LoadSavedData" disabled="@isLoading">Refresh saved data</button>
                <button class="btn btn-secondary" @onclick="SaveGeneratedRota" disabled="@(!generatedRows.Any() || isLoading)">Save rota</button>
                <button class="btn btn-outline-primary" @onclick="ToggleEditMode" disabled="@(!generatedRows.Any())">@(isEditMode ? "Done editing" : "Edit rota")</button>
                <button class="btn btn-outline-dark" @onclick="AddManualRow" disabled="@isLoading">Add manual row</button>
                <button class="btn btn-outline-danger" @onclick="ExportToPdf" disabled="@(!generatedRows.Any())">Export to PDF</button>
            </div>
        </div>
    </header>

    <div class="rota-stats no-print">
        <article class="rota-stat-card">
            <span class="rota-stat-kicker">Team</span>
            <h2>Active staff</h2>
            <p class="rota-stat-value">@staffList.Count(s => s.IsActive)</p>
        </article>
        <article class="rota-stat-card">
            <span class="rota-stat-kicker">Demand</span>
            <h2>Required weekly slots</h2>
            <p class="rota-stat-value">@GetTotalRequiredSlots()</p>
        </article>
        <article class="rota-stat-card">
            <span class="rota-stat-kicker">Output</span>
            <h2>Generated assignments</h2>
            <p class="rota-stat-value">@generatedRows.Count(r => r.StaffName != "Unfilled" && r.StaffName != "No staff required")</p>
        </article>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-info rota-status" role="alert">@statusMessage</div>
    }

    @if (coverageWarnings.Any())
    {
        <div class="alert alert-warning no-print rota-warning" role="alert">
            <strong>Coverage notes:</strong>
            <ul class="mb-0 mt-2">
                @foreach (var warning in coverageWarnings)
                {
                    <li>@warning</li>
                }
            </ul>
        </div>
    }

    @if (generatedRows.Any())
    {
        <section class="rota-shell card">
            <div class="card-body rota-shell-body">
                <div class="rota-section-header">
                    <div>
                        <h2>Generated Weekly Rota</h2>
                        <p class="mb-0">Review the generated schedule, then refine assignments or export when ready.</p>
                    </div>
                    <span class="rota-chip">@generatedRows.Count rows</span>
                </div>

                <div id="rotaPrintArea" class="table-responsive rota-table-wrap">
                    <table class="table table-striped table-bordered align-middle rota-table">
                        <thead>
                            <tr>
                                <th>Staff name</th>
                                @foreach (var day in WeekDays)
                                {
                                    <th>@day</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var staffName in GetDisplayedStaffNames())
                            {
                                <tr>
                                    <td class="fw-semibold @(staffName == "Unfilled" ? "text-danger" : string.Empty)">@staffName</td>
                                    @foreach (var day in WeekDays)
                                    {
                                        var cellRows = GetRowsForStaffAndDay(staffName, day).ToList();
                                        <td class="@(staffName == "Unfilled" && cellRows.Any() ? "table-warning" : string.Empty)">
                                            @if (cellRows.Any())
                                            {
                                                @foreach (var assignment in cellRows)
                                                {
                                                    <div class="mb-1">@FormatTimeRange(assignment)</div>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (isEditMode)
                {
                    <div class="mt-4 no-print rota-edit-block">
                        <div class="rota-section-header rota-section-header--sub">
                            <div>
                                <h3 class="h5 mb-1">Edit assignments</h3>
                                <p class="mb-0">Refine individual rows without regenerating the full rota.</p>
                            </div>
                        </div>
                        <div class="table-responsive rota-table-wrap">
                            <table class="table table-striped table-bordered align-middle rota-edit-table">
                                <thead>
                                    <tr>
                                        <th>Day</th>
                                        <th>Name</th>
                                        <th>Start</th>
                                        <th>End</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in generatedRows)
                                    {
                                        <tr>
                                            <td>
                                                @if (row.StaffName != "No staff required")
                                                {
                                                    <select class="form-select" @bind="row.Day">
                                                        @foreach (var day in WeekDays)
                                                        {
                                                            <option value="@day">@day</option>
                                                        }
                                                    </select>
                                                }
                                                else
                                                {
                                                    @row.Day
                                                }
                                            </td>
                                            <td class="@(row.StaffName == "Unfilled" ? "text-danger fw-semibold" : string.Empty)">
                                                @if (row.StaffName != "No staff required")
                                                {
                                                    <select class="form-select" value="@row.EmployeeID" @onchange="@(e => UpdateAssignedStaff(e, row))">
                                                        <option value="">Unfilled</option>
                                                        @foreach (var staff in GetSelectableStaffForDay(row.Day))
                                                        {
                                                            <option value="@staff.EmployeeID">@GetStaffOptionLabel(staff, row.Day)</option>
                                                        }
                                                    </select>
                                                }
                                                else
                                                {
                                                    @row.StaffName
                                                }
                                            </td>
                                            <td>
                                                @if (row.StaffName != "No staff required")
                                                {
                                                    <input type="time" class="form-control" value="@row.StartTime" @onchange="@(e => row.StartTime = e.Value?.ToString() ?? string.Empty)" />
                                                }
                                                else
                                                {
                                                    @row.StartTime
                                                }
                                            </td>
                                            <td>
                                                @if (row.StaffName != "No staff required")
                                                {
                                                    <input type="time" class="form-control" value="@row.EndTime" @onchange="@(e => row.EndTime = e.Value?.ToString() ?? string.Empty)" />
                                                }
                                                else
                                                {
                                                    @row.EndTime
                                                }
                                            </td>
                                            <td>
                                                @if (row.StaffName != "No staff required")
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => RemoveRow(row))">Remove</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
    else if (!isLoading)
    {
        <div class="rota-empty-state">
            <h2>No rota generated yet</h2>
            <p>Click <strong>Generate rota</strong> to build the weekly table using your saved staffing rules.</p>
        </div>
    }
</section>

@code {
    private List<StaffInput> staffList = new();
    private DayRequirements weeklyRequirements = CreateDefaultRequirements();
    private DaySpecificStartTimes dailyOpeningTimes = new();
    private DaySpecificCoverageRequirements dailyCoverageTargets = new();
    private RotaGenerationOptions rotaGenerationOptions = new();
    private EndTimeRequirements weeklyEndTimes = new();
    private DaySpecificJobRoles dailyJobRoles = new();
    private List<GeneratedRotaRow> generatedRows = new();
    private List<string> coverageWarnings = new();
    private bool isLoading = true;
    private bool isEditMode = false;
    private string statusMessage = string.Empty;

    private readonly string[] WeekDays = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSavedData();
            StateHasChanged();
        }
    }

    private async Task LoadSavedData()
    {
        isLoading = true;

        try
        {
            staffList = await localStorage.GetItemAsync<List<StaffInput>>("stafflist") ?? new List<StaffInput>();
            weeklyRequirements = await localStorage.GetItemAsync<DayRequirements>("weeklyDayRequirements") ?? CreateDefaultRequirements();
            dailyOpeningTimes = await localStorage.GetItemAsync<DaySpecificStartTimes>("daySpecificStartTimes") ?? new DaySpecificStartTimes();
            dailyCoverageTargets = await localStorage.GetItemAsync<DaySpecificCoverageRequirements>("daySpecificCoverageRequirements") ?? new DaySpecificCoverageRequirements();
            rotaGenerationOptions = await localStorage.GetItemAsync<RotaGenerationOptions>("rotaGenerationOptions") ?? new RotaGenerationOptions();
            weeklyEndTimes = await localStorage.GetItemAsync<EndTimeRequirements>("endTimeRequirements") ?? new EndTimeRequirements();
            dailyJobRoles = await localStorage.GetItemAsync<DaySpecificJobRoles>("daySpecificJobRoles") ?? new DaySpecificJobRoles();
            generatedRows = await localStorage.GetItemAsync<List<GeneratedRotaRow>>("generatedRotaRows") ?? new List<GeneratedRotaRow>();

            EnsureStaffAvailabilityKeys();
            NormalizeGeneratedRows();
            statusMessage = $"Loaded {staffList.Count(s => s.IsActive)} active staff members and {GetTotalRequiredSlots()} required weekly slots.";

            if (generatedRows.Any())
            {
                statusMessage += $" A saved rota with {generatedRows.Count} rows is ready to review.";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Unable to load saved rota data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void EnsureStaffAvailabilityKeys()
    {
        foreach (var staff in staffList)
        {
            staff.DailyAvailability ??= new Dictionary<string, bool>();

            foreach (var day in WeekDays)
            {
                if (!staff.DailyAvailability.ContainsKey(day))
                {
                    staff.DailyAvailability[day] = false;
                }
            }
        }
    }

    private async Task GenerateRota()
    {
        coverageWarnings.Clear();
        generatedRows.Clear();
        isEditMode = false;

        var activeStaff = staffList.Where(s => s.IsActive).ToList();
        if (!activeStaff.Any())
        {
            statusMessage = "No active staff found. Add staff in Staff Manager first.";
            return;
        }

        var assignmentCounts = activeStaff.ToDictionary(s => s.EmployeeID, _ => 0);
        var adjustedStartCount = 0;

        foreach (var day in WeekDays)
        {
            var requiredCount = GetRequiredStaffForDay(day);
            var dayRoles = dailyJobRoles.JobRolesByDay.TryGetValue(day, out var roles)
                ? roles
                    .Select(NormalizeRoleName)
                    .Where(role => !string.IsNullOrWhiteSpace(role))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList()
                : new List<string>();
            var remainingDayRoles = dayRoles.ToList();

            if (requiredCount <= 0)
            {
                generatedRows.Add(new GeneratedRotaRow
                {
                    Day = day,
                    StaffName = "No staff required",
                    Role = "—",
                    StartTime = "—",
                    EndTime = "—"
                });
                continue;
            }

            var openingTime = GetOpeningTimeForDay(day);
            var coverageRequirement = GetCoverageRequirementForDay(day);
            var earlyCoverageCount = Math.Min(requiredCount, Math.Max(0, coverageRequirement.RequiredStaff));
            var coverageTime = coverageRequirement.RequiredByTime < openingTime
                ? openingTime
                : coverageRequirement.RequiredByTime;

            if (coverageRequirement.RequiredStaff > requiredCount)
            {
                coverageWarnings.Add($"{day}: the by-time target was capped at the daily staffing requirement of {requiredCount}.");
            }

            var assignedIds = new HashSet<string>();
            var dayRows = new List<GeneratedRotaRow>();
            var availableForDay = activeStaff.Where(staff => IsStaffAvailableForDay(staff, day)).ToList();

            if (rotaGenerationOptions.AlwaysScheduleManagerFirst)
            {
                var managerRequiredByTime = openingTime;
                var managerCandidate = PickBestCandidate(
                    availableForDay.Where(staff => staff.IsManager),
                    assignedIds,
                    assignmentCounts,
                    day,
                    managerRequiredByTime);

                if (managerCandidate is null)
                {
                    coverageWarnings.Add($"{day}: manager-first is enabled, but no available manager could be scheduled first.");
                }
                else
                {
                    if (NeedsStartTimeOverride(managerCandidate, day, managerRequiredByTime))
                    {
                        adjustedStartCount++;
                    }

                    assignedIds.Add(managerCandidate.EmployeeID);
                    assignmentCounts[managerCandidate.EmployeeID]++;
                    dayRows.Add(BuildRotaRow(day, managerCandidate, ChooseDisplayRole(managerCandidate, remainingDayRoles), managerRequiredByTime));
                    remainingDayRoles = GetUncoveredRoles(dayRoles, dayRows);
                }
            }

            while (dayRows.Count < requiredCount)
            {
                var requiredByTime = dayRows.Count < earlyCoverageCount ? coverageTime : (TimeOnly?)null;

                var rolePriorityCandidates = remainingDayRoles.Any()
                    ? availableForDay.Where(staff => remainingDayRoles.Any(role => StaffHasRole(staff, role)))
                    : availableForDay;

                var candidate = PickBestCandidate(rolePriorityCandidates, assignedIds, assignmentCounts, day, requiredByTime)
                    ?? PickBestCandidate(availableForDay, assignedIds, assignmentCounts, day, requiredByTime);

                if (candidate is null)
                {
                    break;
                }

                if (NeedsStartTimeOverride(candidate, day, requiredByTime))
                {
                    adjustedStartCount++;
                }

                assignedIds.Add(candidate.EmployeeID);
                assignmentCounts[candidate.EmployeeID]++;
                dayRows.Add(BuildRotaRow(day, candidate, ChooseDisplayRole(candidate, remainingDayRoles), requiredByTime));
                remainingDayRoles = GetUncoveredRoles(dayRoles, dayRows);
            }

            foreach (var uncoveredRole in remainingDayRoles)
            {
                coverageWarnings.Add($"{day}: no scheduled staff member covers required role '{uncoveredRole}'.");
            }

            if (dayRows.Count < requiredCount)
            {
                coverageWarnings.Add($"{day}: only {dayRows.Count} of {requiredCount} required staff could be scheduled.");

                while (dayRows.Count < requiredCount)
                {
                    var unfilledStartTime = dayRows.Count < earlyCoverageCount ? coverageTime : openingTime;
                    var unfilledRole = remainingDayRoles.FirstOrDefault() ?? "General";

                    dayRows.Add(new GeneratedRotaRow
                    {
                        Day = day,
                        StaffName = "Unfilled",
                        Role = unfilledRole,
                        StartTime = unfilledStartTime.ToString("HH:mm"),
                        EndTime = GetFallbackEndTime(unfilledStartTime).ToString("HH:mm")
                    });
                }
            }

            generatedRows.AddRange(dayRows);
        }

        var adjustmentSummary = adjustedStartCount > 0
            ? $" {adjustedStartCount} start time(s) were brought forward to meet saved coverage and manager-first rules."
            : string.Empty;

        statusMessage = $"Rota generated with {generatedRows.Count(r => r.StaffName != "Unfilled" && r.StaffName != "No staff required")} staff assignments across the week.{adjustmentSummary}";
    }

    private StaffInput? PickBestCandidate(IEnumerable<StaffInput> candidates, HashSet<string> assignedIds, Dictionary<string, int> assignmentCounts, string day, TimeOnly? requiredByTime = null)
    {
        return candidates
            .Where(staff => !assignedIds.Contains(staff.EmployeeID))
            .OrderBy(staff => requiredByTime.HasValue && NeedsStartTimeOverride(staff, day, requiredByTime) ? 1 : 0)
            .ThenBy(staff => HasMetPreferredDaysTarget(staff, assignmentCounts) ? 1 : 0)
            .ThenBy(staff => GetAllocationLoadScore(staff, assignmentCounts))
            .ThenByDescending(GetPreferredDaysTarget)
            .ThenBy(staff => assignmentCounts[staff.EmployeeID])
            .ThenBy(staff => GetAssignedStartTime(staff, day))
            .ThenBy(staff => staff.IsManager)
            .ThenBy(staff => staff.NewStaffName)
            .FirstOrDefault();
    }

    private GeneratedRotaRow BuildRotaRow(string day, StaffInput staff, string role, TimeOnly? requiredByTime = null)
    {
        var startTime = GetAssignedStartTime(staff, day, requiredByTime);
        var endTime = GetAssignedEndTime(staff, startTime);

        return new GeneratedRotaRow
        {
            Day = day,
            EmployeeID = staff.EmployeeID,
            StaffName = staff.NewStaffName,
            Role = string.IsNullOrWhiteSpace(role) ? "General" : role,
            StartTime = startTime.ToString("HH:mm"),
            EndTime = endTime.ToString("HH:mm")
        };
    }

    private async Task SaveGeneratedRota()
    {
        NormalizeGeneratedRows();
        await localStorage.SetItemAsync("generatedRotaRows", generatedRows);
        statusMessage = $"Saved {generatedRows.Count} rota rows locally.";
    }

    private async Task ExportToPdf()
    {
        try
        {
            statusMessage = "Preparing PDF...";
            StateHasChanged();

            var fileName = $"rota_{DateTime.Now:yyyyMMdd_HHmm}.pdf";
            await GeneratePdfReport(fileName);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"PDF export error: {ex}");
            statusMessage = $"PDF export failed: {ex.Message}";
        }
    }

    private async Task GeneratePdfReport(string fileName)
    {
        try
        {
            var pdfBytes = GenerateRotaPdf();
            var saveResult = await SavePdfWithPickerAsync(fileName, pdfBytes);

            if (string.IsNullOrWhiteSpace(saveResult.Path))
            {
                statusMessage = "PDF export cancelled. No file was saved.";
                return;
            }

            statusMessage = saveResult.UsedFallback
                ? $"Save picker unavailable. PDF saved automatically to: {saveResult.Path}"
                : $"PDF saved to: {saveResult.Path}";
            System.Diagnostics.Debug.WriteLine($"PDF rota exported to: {saveResult.Path}");
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to export: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"Export error: {ex}");
        }
    }

    private static async Task<(string? Path, bool UsedFallback)> SavePdfWithPickerAsync(string fileName, byte[] pdfBytes)
    {
        var tempPath = Path.Combine(FileSystem.CacheDirectory, fileName);
        await File.WriteAllBytesAsync(tempPath, pdfBytes);

#if MACCATALYST || IOS
        var tcs = new TaskCompletionSource<string?>();

        await MainThread.InvokeOnMainThreadAsync(async () =>
        {
            try
            {
                var sourceUrl = Foundation.NSUrl.FromFilename(tempPath);
                var picker = new UIKit.UIDocumentPickerViewController(new[] { sourceUrl }, true);
                picker.ShouldShowFileExtensions = true;
                picker.ModalPresentationStyle = UIKit.UIModalPresentationStyle.FormSheet;

                picker.DidPickDocumentAtUrls += (_, args) =>
                {
                    var pickedUrl = args.Urls?.FirstOrDefault();
                    tcs.TrySetResult(pickedUrl?.Path);
                };

                picker.WasCancelled += (_, _) => tcs.TrySetResult(null);

                var root = Microsoft.Maui.ApplicationModel.Platform.GetCurrentUIViewController();

                while (root?.PresentedViewController is not null)
                {
                    root = root.PresentedViewController;
                }

                if (root is null)
                {
                    var fallbackPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), fileName);
                    await File.WriteAllBytesAsync(fallbackPath, pdfBytes);
                    tcs.TrySetResult(fallbackPath);
                    return;
                }

                root.PresentViewController(picker, true, null);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Save picker error: {ex}");
                var fallbackPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), fileName);
                await File.WriteAllBytesAsync(fallbackPath, pdfBytes);
                tcs.TrySetResult(fallbackPath);
            }
        });

        var chosenPath = await tcs.Task;
        var didUseFallback = !string.IsNullOrWhiteSpace(chosenPath)
            && string.Equals(Path.GetDirectoryName(chosenPath), Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), StringComparison.OrdinalIgnoreCase);

        return (chosenPath, didUseFallback);
#else
        var fallbackPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments), fileName);
        await File.WriteAllBytesAsync(fallbackPath, pdfBytes);
        return (fallbackPath, true);
#endif
    }

    private byte[] GenerateRotaPdf()
    {
        const double pageWidth = 1008;
        const double pageHeight = 612;
        const double margin = 18;
        var titleY = pageHeight - margin - 8;
        var tableTopY = titleY - 20;
        const double headerHeight = 24;
        const double rowPadding = 4;
        const double textLineHeight = 11;
        var footerY = margin - 4;

        var firstColumnWidth = 155d;
        var dayColumnWidth = (pageWidth - (margin * 2) - firstColumnWidth) / WeekDays.Length;
        var columnWidths = new List<double> { firstColumnWidth };
        for (var i = 0; i < WeekDays.Length; i++)
        {
            columnWidths.Add(dayColumnWidth);
        }

        var tableRows = BuildPdfTableRows(columnWidths, rowPadding);
        var pageContents = new List<string>();
        var rowIndex = 0;
        var pageNumber = 1;

        do
        {
            var content = new System.Text.StringBuilder();
            AppendPdfText(content, "F2", 13.5, margin, titleY, "Weekly Rota");
            AppendPdfText(content, "F1", 9.5, margin + 108, titleY + 1, $"Generated: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");

            var yTop = tableTopY;
            var headerLabels = new[] { "Staff name" }.Concat(WeekDays).ToList();
            AppendPdfHeaderRow(content, margin, yTop, headerHeight, columnWidths, headerLabels);
            yTop -= headerHeight;

            if (!tableRows.Any())
            {
                AppendPdfBorderedCell(content, margin, yTop, pageWidth - (margin * 2), 28, 1.0);
                AppendPdfText(content, "F1", 10, margin + 6, yTop - 18, "No rota rows to export.");
                yTop -= 28;
            }

            while (rowIndex < tableRows.Count)
            {
                var row = tableRows[rowIndex];
                var maxLines = Math.Max(1, row.Max(cell => cell.Count));
                var rowHeight = (rowPadding * 2) + (maxLines * textLineHeight);

                if (yTop - rowHeight < footerY + 12)
                {
                    break;
                }

                var x = margin;
                for (var col = 0; col < row.Count; col++)
                {
                    var width = columnWidths[col];
                    AppendPdfBorderedCell(content, x, yTop, width, rowHeight, 1.0);

                    var lineY = yTop - rowPadding - 8;
                    foreach (var line in row[col])
                    {
                        AppendPdfText(content, "F1", 9.2, x + 4, lineY, line);
                        lineY -= textLineHeight;
                    }

                    x += width;
                }

                yTop -= rowHeight;
                rowIndex++;
            }

            AppendPdfText(content, "F1", 9, pageWidth - margin - 50, footerY, $"Page {pageNumber}");
            pageContents.Add(content.ToString());
            pageNumber++;
        }
        while (rowIndex < tableRows.Count || pageContents.Count == 0);

        return BuildPdfDocument(pageContents, pageWidth, pageHeight);
    }

    private static string EscapePdfText(string text)
    {
        return text
            .Replace("\\", "\\\\")
            .Replace("(", "\\(")
            .Replace(")", "\\)");
    }

    private List<List<List<string>>> BuildPdfTableRows(List<double> columnWidths, double padding)
    {
        var rows = new List<List<List<string>>>();

        foreach (var staffName in GetDisplayedStaffNames())
        {
            var row = new List<List<string>>
            {
                WrapPdfCellText(staffName, columnWidths[0], padding)
            };

            foreach (var day in WeekDays)
            {
                var ranges = GetRowsForStaffAndDay(staffName, day)
                    .Select(FormatTimeRange)
                    .ToList();

                var lines = ranges.Any()
                    ? ranges.SelectMany(range => WrapPdfCellText(range, columnWidths[1], padding)).ToList()
                    : new List<string> { "-" };

                row.Add(lines);
            }

            rows.Add(row);
        }

        return rows;
    }

    private static List<string> WrapPdfCellText(string text, double cellWidth, double padding)
    {
        var sanitized = string.IsNullOrWhiteSpace(text) ? "-" : text.Trim();
        var maxChars = Math.Max(6, (int)Math.Floor((cellWidth - (padding * 2) - 6) / 5.1));
        var output = new List<string>();

        foreach (var sourceLine in sanitized.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (sourceLine.Length <= maxChars)
            {
                output.Add(sourceLine);
                continue;
            }

            var words = sourceLine.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (words.Length == 0)
            {
                output.Add(sourceLine[..Math.Min(sourceLine.Length, maxChars)]);
                continue;
            }

            var lineBuilder = new System.Text.StringBuilder();
            foreach (var word in words)
            {
                var next = lineBuilder.Length == 0 ? word : $"{lineBuilder} {word}";
                if (next.Length <= maxChars)
                {
                    if (lineBuilder.Length > 0)
                    {
                        lineBuilder.Append(' ');
                    }

                    lineBuilder.Append(word);
                    continue;
                }

                if (lineBuilder.Length > 0)
                {
                    output.Add(lineBuilder.ToString());
                    lineBuilder.Clear();
                }

                if (word.Length > maxChars)
                {
                    output.Add(word[..(maxChars - 1)] + "~");
                }
                else
                {
                    lineBuilder.Append(word);
                }
            }

            if (lineBuilder.Length > 0)
            {
                output.Add(lineBuilder.ToString());
            }
        }

        return output.Any() ? output : new List<string> { "-" };
    }

    private static byte[] BuildPdfDocument(List<string> pageContents, double pageWidth, double pageHeight)
    {
        using var stream = new MemoryStream();
        using var writer = new StreamWriter(stream, System.Text.Encoding.ASCII, leaveOpen: true);

        void WriteAscii(string text)
        {
            writer.Write(text);
            writer.Flush();
        }

        var totalObjects = 4 + (pageContents.Count * 2);
        var offsets = new long[totalObjects + 1];

        WriteAscii("%PDF-1.4\n");

        void WriteObject(int number, string body)
        {
            offsets[number] = stream.Position;
            WriteAscii($"{number} 0 obj\n{body}\nendobj\n");
        }

        WriteObject(1, "<< /Type /Catalog /Pages 2 0 R >>");

        var kids = string.Join(" ", Enumerable.Range(0, pageContents.Count).Select(index => $"{5 + (index * 2)} 0 R"));
        WriteObject(2, $"<< /Type /Pages /Count {pageContents.Count} /Kids [{kids}] >>");
        WriteObject(3, "<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>");
        WriteObject(4, "<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold >>");

        for (var index = 0; index < pageContents.Count; index++)
        {
            var pageObj = 5 + (index * 2);
            var contentObj = pageObj + 1;
            var contentBytes = System.Text.Encoding.ASCII.GetBytes(pageContents[index]);

            WriteObject(pageObj,
                $"<< /Type /Page /Parent 2 0 R /MediaBox [0 0 {PdfNumber(pageWidth)} {PdfNumber(pageHeight)}] /Resources << /Font << /F1 3 0 R /F2 4 0 R >> >> /Contents {contentObj} 0 R >>");

            offsets[contentObj] = stream.Position;
            WriteAscii($"{contentObj} 0 obj\n<< /Length {contentBytes.Length} >>\nstream\n");
            stream.Write(contentBytes, 0, contentBytes.Length);
            WriteAscii("\nendstream\nendobj\n");
        }

        var xrefPosition = stream.Position;
        WriteAscii($"xref\n0 {offsets.Length}\n");
        WriteAscii("0000000000 65535 f \n");

        for (var index = 1; index < offsets.Length; index++)
        {
            WriteAscii($"{offsets[index]:0000000000} 00000 n \n");
        }

        WriteAscii($"trailer\n<< /Size {offsets.Length} /Root 1 0 R >>\nstartxref\n{xrefPosition}\n%%EOF");
        return stream.ToArray();
    }

    private static void AppendPdfHeaderRow(System.Text.StringBuilder builder, double xStart, double yTop, double height, IReadOnlyList<double> widths, IReadOnlyList<string> labels)
    {
        var x = xStart;
        for (var index = 0; index < widths.Count; index++)
        {
            var width = widths[index];
            var y = yTop - height;
            builder.AppendLine("q");
            builder.AppendLine("0.82 g");
            builder.AppendLine($"{PdfNumber(x)} {PdfNumber(y)} {PdfNumber(width)} {PdfNumber(height)} re f");
            builder.AppendLine("Q");

            AppendPdfBorderedCell(builder, x, yTop, width, height, 1.0);
            AppendPdfText(builder, "F2", 9.8, x + 4, yTop - 15, labels[index]);
            x += width;
        }
    }

    private static void AppendPdfBorderedCell(System.Text.StringBuilder builder, double x, double yTop, double width, double height, double lineWidth)
    {
        var y = yTop - height;
        builder.AppendLine($"{PdfNumber(lineWidth)} w");
        builder.AppendLine($"{PdfNumber(x)} {PdfNumber(y)} {PdfNumber(width)} {PdfNumber(height)} re S");
    }

    private static void AppendPdfText(System.Text.StringBuilder builder, string fontName, double size, double x, double y, string text)
    {
        builder.AppendLine("BT");
        builder.AppendLine($"/{fontName} {PdfNumber(size)} Tf");
        builder.AppendLine($"1 0 0 1 {PdfNumber(x)} {PdfNumber(y)} Tm");
        builder.AppendLine($"({EscapePdfText(text)}) Tj");
        builder.AppendLine("ET");
    }

    private static string PdfNumber(double value)
    {
        return value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    }

    private void ToggleEditMode()
    {
        isEditMode = !isEditMode;

        if (isEditMode)
        {
            NormalizeGeneratedRows();
        }
    }

    private void AddManualRow()
    {
        generatedRows.Add(new GeneratedRotaRow
        {
            Day = WeekDays[0],
            StaffName = "Unfilled",
            Role = "General",
            StartTime = GetOpeningTimeForDay(WeekDays[0]).ToString("HH:mm"),
            EndTime = GetFallbackEndTime(GetOpeningTimeForDay(WeekDays[0])).ToString("HH:mm")
        });

        isEditMode = true;
    }

    private void RemoveRow(GeneratedRotaRow row)
    {
        generatedRows.Remove(row);
    }

    private IEnumerable<string> GetDisplayedStaffNames()
    {
        return generatedRows
            .Where(row => row.StaffName != "No staff required")
            .Select(row => row.StaffName)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct()
            .OrderBy(name => name == "Unfilled" ? 1 : 0)
            .ThenBy(name => name);
    }

    private IEnumerable<GeneratedRotaRow> GetRowsForStaffAndDay(string staffName, string day)
    {
        return generatedRows
            .Where(row => row.StaffName == staffName && row.Day == day && row.StaffName != "No staff required")
            .OrderBy(row => TimeOnly.TryParse(row.StartTime, out var time) ? time : new TimeOnly(0, 0));
    }

    private static string FormatTimeRange(GeneratedRotaRow row)
    {
        var hasStart = !string.IsNullOrWhiteSpace(row.StartTime) && row.StartTime != "—";
        var hasEnd = !string.IsNullOrWhiteSpace(row.EndTime) && row.EndTime != "—";

        if (!hasStart && !hasEnd)
        {
            return "—";
        }

        if (hasStart && hasEnd)
        {
            return $"{row.StartTime} - {row.EndTime}";
        }

        return hasStart ? row.StartTime : row.EndTime;
    }

    private IEnumerable<StaffInput> GetSelectableStaffForDay(string day)
    {
        return staffList
            .Where(s => s.IsActive)
            .OrderByDescending(s => IsStaffAvailableForDay(s, day))
            .ThenBy(s => s.NewStaffName);
    }

    private string GetStaffOptionLabel(StaffInput staff, string day)
    {
        return IsStaffAvailableForDay(staff, day)
            ? staff.NewStaffName
            : $"{staff.NewStaffName} (outside availability)";
    }

    private void UpdateAssignedStaff(ChangeEventArgs e, GeneratedRotaRow row)
    {
        row.EmployeeID = e?.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(row.EmployeeID))
        {
            row.StaffName = "Unfilled";
            return;
        }

        var selectedStaff = staffList.FirstOrDefault(staff => staff.EmployeeID == row.EmployeeID);
        if (selectedStaff == null)
        {
            row.StaffName = "Unfilled";
            row.EmployeeID = string.Empty;
            return;
        }

        row.StaffName = selectedStaff.NewStaffName;

        var dayRoles = dailyJobRoles.JobRolesByDay.TryGetValue(row.Day, out var roles)
            ? roles.Select(NormalizeRoleName)
            : Enumerable.Empty<string>();
        row.Role = ChooseDisplayRole(selectedStaff, dayRoles);

        var startTime = GetAssignedStartTime(selectedStaff, row.Day);
        row.StartTime = startTime.ToString("HH:mm");
        row.EndTime = GetAssignedEndTime(selectedStaff, startTime).ToString("HH:mm");
    }

    private void NormalizeGeneratedRows()
    {
        foreach (var row in generatedRows)
        {
            if (!string.IsNullOrWhiteSpace(row.StaffName) && row.StaffName != "Unfilled" && row.StaffName != "No staff required" && string.IsNullOrWhiteSpace(row.EmployeeID))
            {
                row.EmployeeID = staffList.FirstOrDefault(staff => staff.NewStaffName == row.StaffName)?.EmployeeID ?? string.Empty;
            }

            if (row.StaffName != "No staff required")
            {
                if (!TimeOnly.TryParse(row.StartTime, out _))
                {
                    row.StartTime = GetOpeningTimeForDay(row.Day).ToString("HH:mm");
                }

                if (!TimeOnly.TryParse(row.EndTime, out _))
                {
                    var parsedStart = TimeOnly.TryParse(row.StartTime, out var start) ? start : GetOpeningTimeForDay(row.Day);
                    row.EndTime = GetFallbackEndTime(parsedStart).ToString("HH:mm");
                }
            }
        }
    }

    private bool IsStaffAvailableForDay(StaffInput staff, string day)
    {
        if (!staff.IsAvailableThisWeek)
        {
            return false;
        }

        if (staff.DailyAvailability.TryGetValue(day, out var available) && available)
        {
            return true;
        }

        if (string.IsNullOrWhiteSpace(staff.WorkingDays))
        {
            return false;
        }

        return staff.WorkingDays
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Any(savedDay => string.Equals(savedDay, day, StringComparison.OrdinalIgnoreCase));
    }

    private TimeOnly GetAssignedStartTime(StaffInput staff, string day, TimeOnly? requiredByTime = null)
    {
        var openingTime = GetOpeningTimeForDay(day);
        var assignedStartTime = openingTime;

        if (TimeOnly.TryParse(staff.StartTime, out var staffStartTime) && staffStartTime > openingTime)
        {
            assignedStartTime = staffStartTime;
        }

        if (requiredByTime.HasValue)
        {
            var targetTime = requiredByTime.Value < openingTime ? openingTime : requiredByTime.Value;
            if (assignedStartTime > targetTime)
            {
                return targetTime;
            }
        }

        return assignedStartTime;
    }

    private bool NeedsStartTimeOverride(StaffInput staff, string day, TimeOnly? requiredByTime)
    {
        if (!requiredByTime.HasValue)
        {
            return false;
        }

        var openingTime = GetOpeningTimeForDay(day);
        var targetTime = requiredByTime.Value < openingTime ? openingTime : requiredByTime.Value;
        return GetAssignedStartTime(staff, day) > targetTime;
    }

    private bool HasMetPreferredDaysTarget(StaffInput staff, Dictionary<string, int> assignmentCounts)
    {
        return assignmentCounts[staff.EmployeeID] >= GetPreferredDaysTarget(staff);
    }

    private double GetAllocationLoadScore(StaffInput staff, Dictionary<string, int> assignmentCounts)
    {
        var preferredDaysTarget = GetPreferredDaysTarget(staff);
        return preferredDaysTarget <= 0
            ? assignmentCounts[staff.EmployeeID]
            : (double)assignmentCounts[staff.EmployeeID] / preferredDaysTarget;
    }

    private int GetPreferredDaysTarget(StaffInput staff)
    {
        var availableDaysCount = CountAvailableDays(staff);

        if (staff.PreferredDaysPerWeek <= 0)
        {
            return Math.Max(1, availableDaysCount);
        }

        if (availableDaysCount <= 0)
        {
            return Math.Max(1, staff.PreferredDaysPerWeek);
        }

        return Math.Clamp(staff.PreferredDaysPerWeek, 1, availableDaysCount);
    }

    private int CountAvailableDays(StaffInput staff)
    {
        var explicitAvailability = staff.DailyAvailability?.Count(x => x.Value) ?? 0;
        if (explicitAvailability > 0)
        {
            return explicitAvailability;
        }

        if (string.IsNullOrWhiteSpace(staff.WorkingDays))
        {
            return 0;
        }

        return staff.WorkingDays
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();
    }

    private CoverageRequirement GetCoverageRequirementForDay(string day)
    {
        if (dailyCoverageTargets.CoverageByDay.TryGetValue(day, out var coverageRequirement))
        {
            return coverageRequirement;
        }

        return new CoverageRequirement
        {
            RequiredStaff = 0,
            RequiredByTime = GetOpeningTimeForDay(day)
        };
    }

    private TimeOnly GetAssignedEndTime(StaffInput staff, TimeOnly startTime)
    {
        if (TimeOnly.TryParse(staff.EndTime, out var staffEndTime) && staffEndTime > startTime)
        {
            return staffEndTime;
        }

        return GetFallbackEndTime(startTime);
    }

    private TimeOnly GetFallbackEndTime(TimeOnly startTime)
    {
        if (weeklyEndTimes.EndTimes.Any())
        {
            var configuredEndTime = weeklyEndTimes.EndTimes.OrderByDescending(time => time).First();
            if (configuredEndTime > startTime)
            {
                return configuredEndTime;
            }
        }

        return startTime.Add(TimeSpan.FromHours(8));
    }

    private TimeOnly GetOpeningTimeForDay(string day)
    {
        if (dailyOpeningTimes.StartTimesByDay.TryGetValue(day, out var openingTime))
        {
            return openingTime;
        }

        return new TimeOnly(9, 0);
    }

    private bool StaffHasRole(StaffInput staff, string role)
    {
        var normalizedRole = NormalizeRoleName(role);
        if (string.IsNullOrWhiteSpace(normalizedRole))
        {
            return false;
        }

        return staff.JobRoles.Any(job => string.Equals(NormalizeRoleName(job), normalizedRole, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsRoleCoveredByScheduledStaff(string role, IEnumerable<GeneratedRotaRow> scheduledRows)
    {
        var normalizedRole = NormalizeRoleName(role);
        if (string.IsNullOrWhiteSpace(normalizedRole))
        {
            return true;
        }

        return scheduledRows
            .Where(row => !string.IsNullOrWhiteSpace(row.EmployeeID))
            .Select(row => staffList.FirstOrDefault(staff => staff.EmployeeID == row.EmployeeID))
            .Any(staff => staff != null &&
                ((staff.IsManager && string.Equals(normalizedRole, "Manager", StringComparison.OrdinalIgnoreCase))
                || StaffHasRole(staff, normalizedRole)));
    }

    private List<string> GetUncoveredRoles(IEnumerable<string> requiredRoles, IEnumerable<GeneratedRotaRow> scheduledRows)
    {
        return requiredRoles
            .Select(NormalizeRoleName)
            .Where(role => !string.IsNullOrWhiteSpace(role))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Where(role => !IsRoleCoveredByScheduledStaff(role, scheduledRows))
            .ToList();
    }

    private static string NormalizeRoleName(string? role)
    {
        return role?.Trim() ?? string.Empty;
    }

    private string ChooseDisplayRole(StaffInput staff, IEnumerable<string> dayRoles)
    {
        var matchingRole = dayRoles
            .Select(NormalizeRoleName)
            .FirstOrDefault(role => StaffHasRole(staff, role));

        if (!string.IsNullOrWhiteSpace(matchingRole))
        {
            return matchingRole;
        }

        if (staff.IsManager)
        {
            return "Manager";
        }

        return staff.JobRoles
            .Select(NormalizeRoleName)
            .FirstOrDefault(role => !string.IsNullOrWhiteSpace(role)) ?? "General";
    }

    private int GetRequiredStaffForDay(string day)
    {
        return day switch
        {
            "Monday" => weeklyRequirements.Monday,
            "Tuesday" => weeklyRequirements.Tuesday,
            "Wednesday" => weeklyRequirements.Wednesday,
            "Thursday" => weeklyRequirements.Thursday,
            "Friday" => weeklyRequirements.Friday,
            "Saturday" => weeklyRequirements.Saturday,
            "Sunday" => weeklyRequirements.Sunday,
            _ => 0
        };
    }

    private int GetTotalRequiredSlots()
    {
        return WeekDays.Sum(GetRequiredStaffForDay);
    }

    private static DayRequirements CreateDefaultRequirements()
    {
        return new DayRequirements
        {
            Monday = 0,
            Tuesday = 0,
            Wednesday = 0,
            Thursday = 0,
            Friday = 0,
            Saturday = 0,
            Sunday = 0
        };
    }

    public class GeneratedRotaRow
    {
        public string Day { get; set; } = string.Empty;
        public string EmployeeID { get; set; } = string.Empty;
        public string StaffName { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public string StartTime { get; set; } = string.Empty;
        public string EndTime { get; set; } = string.Empty;
    }
}
