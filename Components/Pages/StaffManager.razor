@page "/StaffManager" //This is a reference to the href name in the NavMenu.razor file
@rendermode InteractiveServer
@using DayRequirements.Models
@using StaffInput.Models
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject IJSRuntime JS


<PageTitle>Staff Manager</PageTitle>

<h1>Staffing</h1>

<p>This is where you can see all staff currently employed 
    and whether they are currently active and available to be added to the rota.</p>

<button class="btn btn-primary" @onclick="ShowInput">Add Staff</button>

@if (showInput)
{
    <div class="input-container mb-3">
        <input class="form-control mb-2" @bind="newStaffName" placeholder="Enter Staff Name" />

        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="isManager" @bind="newIsManager" />
            <label class="form-check-label" for="isManager">Manager</label>
        </div>

        <div class="mb-2">
            <label class="form-label">Working Days</label>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var day in WeekDays)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="day_@day" checked="@newWorkingDays.Contains(day)" @onchange="@(e => ToggleDay(e, day))" />
                        <label class="form-check-label" for="day_@day">@day</label>
                    </div>
                }
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label" for="startTime">Start Time</label>
            @if (availableStartTimes.Any())
            {
                <select id="startTime" class="form-select" @bind="newStartTime">
                    <option value="">Select a start time</option>
                    @foreach (var time in availableStartTimes)
                    {
                        <option value="@time">@time</option>
                    }
                </select>
            }
            else
            {
                <input id="startTime" class="form-control" type="time" value="@newStartTime" @onchange="OnStartTimeChanged" />
                <div class="form-text">No configured weekly start times found yet.</div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label" for="endTime">End Time</label>
            @if (availableEndTimes.Any())
            {
                <select id="endTime" class="form-select" @bind="newEndTime">
                    <option value="">Select an end time</option>
                    @foreach (var time in availableEndTimes)
                    {
                        <option value="@time">@time</option>
                    }
                </select>
            }
            else
            {
                <input id="endTime" class="form-control" type="time" value="@newEndTime" @onchange="OnEndTimeChanged" />
                <div class="form-text">No configured weekly end times found yet.</div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Job Roles</label>
            @if (availableJobRoles.Any())
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var role in availableJobRoles)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="role_@role" checked="@newJobRoles.Contains(role)" @onchange="@(e => ToggleJobRole(e, role))" />
                            <label class="form-check-label" for="role_@role">@role</label>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="form-text">No job roles configured yet. Configure them in Weekly Preferences.</div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Weekly Availability</label>
            <div class="mb-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SetAllDaysAvailable">Set All Days Available</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearAllDays">Clear All Days</button>
            </div>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var day in WeekDays)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="avail_@day" checked="@newDailyAvailability[day]" @onchange="@(e => ToggleDayAvailability(e, day))" />
                        <label class="form-check-label" for="avail_@day">@day</label>
                    </div>
                }
            </div>
        </div>

        <button class="btn btn-primary" @onclick="SaveStaff">Save</button>
        <button class="btn btn-secondary" @onclick="CancelAddStaff">Cancel</button>
    </div>
}

<h2>Current Staff</h2>

@if (!staffList.Any())
{
    <p>No staff have been added yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Job Roles</th>
                <th>Available Days</th>
                <th>Available this week</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var staff in staffList)
            {
                <tr>
                    <td>@staff.NewStaffName</td>
                    <td>
                        @if (staff.JobRoles.Any())
                        {
                            <span class="badge bg-info">@string.Join(", ", staff.JobRoles)</span>
                        }
                        else
                        {
                            <span class="text-muted">No roles assigned</span>
                        }
                    </td>
                    <td>
                        @{
                            var availableDays = staff.DailyAvailability
                                .Where(x => x.Value)
                                .Select(x => GetDayAbbreviation(x.Key))
                                .ToList();
                        }
                        @if (availableDays.Any())
                        {
                            <span class="badge bg-success">@string.Join(", ", availableDays)</span>
                        }
                        else
                        {
                            <span class="text-muted">No days available</span>
                        }
                        <button class="btn btn-sm btn-outline-primary ms-2" @onclick="@(() => ShowEditAvailability(staff))">Edit</button>
                    </td>
                    <td>
                        <input type="checkbox" checked="@staff.IsAvailableThisWeek" @onchange="@(e => ToggleAvailability(e, staff))" />
                    </td>
                    <td>
                        <button class="btn btn-danger btn-sm" @onclick="@(() => DeleteStaffWithConfirmation(staff))">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showEditAvailability && editingStaff != null)
{
    <div class="modal d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Weekly Availability - @editingStaff.NewStaffName</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditAvailability"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <button type="button" class="btn btn-sm btn-outline-secondary me-2" @onclick="SetEditDaysAllAvailable">Set All Days</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearEditDays">Clear All Days</button>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var day in WeekDays)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="edit_avail_@day" checked="@editingStaff.DailyAvailability[day]" @onchange="@(e => ToggleEditDayAvailability(e, day))" />
                                <label class="form-check-label" for="edit_avail_@day">@day</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseEditAvailability">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveEditAvailability">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

@code 
{
    private bool showInput = false;
    private string newStaffName = "";
    private bool newIsManager = false;
    private string newStartTime = "";

    private string newEndTime = "";

    private List<string> newWorkingDays = new();
    private List<string> newJobRoles = new();
    private Dictionary<string, bool> newDailyAvailability = new()
    {
        { "Monday", false },
        { "Tuesday", false },
        { "Wednesday", false },
        { "Thursday", false },
        { "Friday", false },
        { "Saturday", false },
        { "Sunday", false }
    };
    private List<StaffInput> staffList = new();
    private StartTimeRequirements weeklyStartTimes = new();
    private List<string> availableStartTimes = new();
    
    private EndTimeRequirements weeklyEndTimes = new();

    private List<string> availableEndTimes = new();
    private JobRoleRequirements weeklyJobRoles = new();
    private List<string> availableJobRoles = new();

    private bool showEditAvailability = false;
    private StaffInput? editingStaff = null;

    private readonly string[] WeekDays = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };

    void ShowInput()
    {
        showInput = true;
        StateHasChanged();
    }

    void CancelAddStaff()
    {
        showInput = false;
        ResetNewStaffForm();
    }

    void ResetNewStaffForm()
    {
        newStaffName = string.Empty;
        newIsManager = false;
        newStartTime = string.Empty;
        newEndTime = string.Empty;
        newWorkingDays.Clear();
        newJobRoles.Clear();
        foreach (var day in WeekDays)
        {
            newDailyAvailability[day] = false;
        }
    }

    async Task SaveStaff()
    {
        if (!string.IsNullOrWhiteSpace(newStaffName))
        {
            var newStaff = new StaffInput
            {
                EmployeeID = Guid.NewGuid().ToString(),
                NewStaffName = newStaffName.Trim(),
                LastNameInitial = string.Empty,
                IsManager = newIsManager,
                WorkingDays = string.Join(", ", newWorkingDays),
                StartTime = newStartTime,
                EndTime = newEndTime,
                IsActive = true,
                IsAvailableThisWeek = false,
                JobRoles = newJobRoles.ToList(),
                DailyAvailability = new Dictionary<string, bool>(newDailyAvailability)
            };

            staffList.Add(newStaff);
            await SaveStaffListAsync();
            ResetNewStaffForm();
            showInput = false;
        }
    }

    void ToggleDay(ChangeEventArgs e, string day)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        if (isChecked)
        {
            if (!newWorkingDays.Contains(day))
            {
                newWorkingDays.Add(day);
            }
        }
        else
        {
            newWorkingDays.Remove(day);
        }
    }

    void ToggleJobRole(ChangeEventArgs e, string role)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        if (isChecked)
        {
            if (!newJobRoles.Contains(role))
            {
                newJobRoles.Add(role);
            }
        }
        else
        {
            newJobRoles.Remove(role);
        }
    }

    void ToggleDayAvailability(ChangeEventArgs e, string day)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        newDailyAvailability[day] = isChecked;
    }

    void SetAllDaysAvailable()
    {
        foreach (var day in WeekDays)
        {
            newDailyAvailability[day] = true;
        }
        StateHasChanged();
    }

    void ClearAllDays()
    {
        foreach (var day in WeekDays)
        {
            newDailyAvailability[day] = false;
        }
        StateHasChanged();
    }

    void ShowEditAvailability(StaffInput staff)
    {
        editingStaff = staff;
        showEditAvailability = true;
        StateHasChanged();
    }

    void CloseEditAvailability()
    {
        showEditAvailability = false;
        editingStaff = null;
        StateHasChanged();
    }

    void ToggleEditDayAvailability(ChangeEventArgs e, string day)
    {
        if (editingStaff != null)
        {
            var isChecked = e?.Value is bool boolValue && boolValue
                || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

            editingStaff.DailyAvailability[day] = isChecked;
        }
    }

    void SetEditDaysAllAvailable()
    {
        if (editingStaff != null)
        {
            foreach (var day in WeekDays)
            {
                editingStaff.DailyAvailability[day] = true;
            }
            StateHasChanged();
        }
    }

    void ClearEditDays()
    {
        if (editingStaff != null)
        {
            foreach (var day in WeekDays)
            {
                editingStaff.DailyAvailability[day] = false;
            }
            StateHasChanged();
        }
    }

    async Task SaveEditAvailability()
    {
        await SaveStaffListAsync();
        CloseEditAvailability();
    }

    void OnStartTimeChanged(ChangeEventArgs e)
    {
        newStartTime = e?.Value?.ToString() ?? string.Empty;
    }

    void OnEndTimeChanged(ChangeEventArgs e)
    {
        newEndTime = e?.Value?.ToString() ?? string.Empty;
    }

    async Task ToggleAvailability(ChangeEventArgs e, StaffInput staff)
    {
        bool isChecked = false;
        
        if (e?.Value is bool boolValue)
        {
            isChecked = boolValue;
        }
        else if (e?.Value is string stringValue)
        {
            isChecked = stringValue == "true" || stringValue == "on";
        }

        staff.IsAvailableThisWeek = isChecked;

        // Override daily availability based on the "Available this week" checkbox
        foreach (var day in WeekDays)
        {
            staff.DailyAvailability[day] = isChecked;
        }

        await SaveStaffListAsync();
    }

    async Task DeleteStaff(StaffInput staff)
    {
        staffList.Remove(staff);
        await SaveStaffListAsync();
    }

    async Task DeleteStaffWithConfirmation(StaffInput staff)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete {staff.NewStaffName}?");
        if (confirmed)
        {
            await DeleteStaff(staff);
        }
    }

    async Task SaveStaffListAsync()
    {
        await localStorage.SetItemAsync("stafflist", staffList);
    }

    private static List<string> BuildStartTimeOptions(StartTimeRequirements startTimes)
    {
        return startTimes.StartTimes
            .Select(t => t.ToString("HH:mm"))
            .Distinct()
            .ToList();
    }

    private static List<string> BuildEndTimeOptions(EndTimeRequirements endTimes)
    {
        return endTimes.EndTimes
            .Select(t => t.ToString("HH:mm"))
            .Distinct()
            .ToList();
    }

    private static string GetDayAbbreviation(string day)
    {
        return day.Substring(0, 3); // Mon, Tue, Wed, etc.
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var data = await localStorage.GetItemAsync<List<StaffInput>>("stafflist");
                if (data != null)
                {
                    staffList = data;
                }

                var savedStartTimes = await localStorage.GetItemAsync<StartTimeRequirements>("startTimeRequirements");
                if (savedStartTimes != null)
                {
                    weeklyStartTimes = savedStartTimes;
                    availableStartTimes = BuildStartTimeOptions(savedStartTimes);
                }

                var savedEndTimes = await localStorage.GetItemAsync<EndTimeRequirements>("endTimeRequirements");
                if (savedEndTimes != null)                
                {
                    weeklyEndTimes = savedEndTimes;
                    availableEndTimes = BuildEndTimeOptions(savedEndTimes);
                }

                var savedJobRoles = await localStorage.GetItemAsync<JobRoleRequirements>("jobRoleRequirements");
                if (savedJobRoles != null)
                {
                    weeklyJobRoles = savedJobRoles;
                    availableJobRoles = weeklyJobRoles.JobRoles.ToList();
                }

                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"StaffManager load error: {ex.Message}");
                await localStorage.RemoveItemAsync("stafflist");
                staffList = new List<StaffInput>();
            }
        }
    }
}
