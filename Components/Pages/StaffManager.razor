@* This route matches the Staff Manager nav link. *@
@page "/StaffManager"
@using DayRequirements.Models
@using StaffInput.Models
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject IJSRuntime JS


<PageTitle>Staff Manager</PageTitle>

<div class="staff-page">
    <header class="staff-header card">
        <div class="card-body staff-header-body">
            <div>
                <h1>Staffing</h1>
                <p class="mb-0">Manage your team, keep availability current, and control who can be added to weekly rotas.</p>
            </div>
            <button class="btn btn-primary" @onclick="ShowInput">Add staff</button>
        </div>
    </header>

    <p class="page-help-text">Use this page to track active staff, preferred working patterns, job roles, and weekly availability.</p>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-info mt-3 status-banner" role="alert">@statusMessage</div>
    }

    @if (showInput)
    {
        <section class="input-container card">
            <div class="card-body staff-form-body">
                <div class="form-heading-row">
                    <h2 class="form-title">Add staff member</h2>
                    <p class="text-muted mb-0">Create a profile with working days, roles, and preferred shift details.</p>
                </div>

                <div class="form-field-group">
                    <label class="form-label" for="newStaffName">Full name</label>
                    <input id="newStaffName" class="form-control" @bind="newStaffName" placeholder="e.g. Alex Johnson" />
                </div>

                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="isManager" @bind="newIsManager" />
                    <label class="form-check-label" for="isManager">Manager</label>
                </div>

                <div class="form-field-group">
                    <label class="form-label">Working days</label>
                    <div class="day-chip-row">
                        @foreach (var day in WeekDays)
                        {
                            <label class="day-chip @(newWorkingDays.Contains(day) ? "day-chip--active" : "")">
                                <input type="checkbox" id="day_@day" checked="@newWorkingDays.Contains(day)" @onchange="@(e => ToggleDay(e, day))" />
                                @day.Substring(0, 3)
                            </label>
                        }
                    </div>
                </div>

                <div class="form-row-2">
                    <div class="form-field-group">
                        <label class="form-label" for="preferredDaysPerWeek">Preferred days / week</label>
                        <input id="preferredDaysPerWeek" class="form-control" type="number" min="0" max="7" @bind="newPreferredDaysPerWeek" />
                        <div class="form-text">Used to balance full-time and part-time allocations.</div>
                    </div>
                    <div class="form-field-group">
                        <label class="form-label" for="hourlyWage">Hourly wage (£)</label>
                        <input id="hourlyWage" class="form-control" @bind="newHourlyWage" placeholder="0.00" type="number" min="0" step="0.01" />
                    </div>
                </div>

                <div class="form-row-2">
                    <div class="form-field-group">
                        <label class="form-label" for="startTime">Start time</label>
                        @if (availableStartTimes.Any())
                        {
                            <select id="startTime" class="form-select" @bind="newStartTime">
                                <option value="">Select start time</option>
                                @foreach (var time in availableStartTimes)
                                {
                                    <option value="@time">@time</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input id="startTime" class="form-control" type="time" value="@newStartTime" @onchange="OnStartTimeChanged" />
                            <div class="form-text">No configured start times found.</div>
                        }
                    </div>
                    <div class="form-field-group">
                        <label class="form-label" for="endTime">End time</label>
                        @if (availableEndTimes.Any())
                        {
                            <select id="endTime" class="form-select" @bind="newEndTime">
                                <option value="">Select end time</option>
                                @foreach (var time in availableEndTimes)
                                {
                                    <option value="@time">@time</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input id="endTime" class="form-control" type="time" value="@newEndTime" @onchange="OnEndTimeChanged" />
                            <div class="form-text">No configured end times found.</div>
                        }
                    </div>
                </div>

                <div class="form-field-group">
                    <label class="form-label">Job roles</label>
                    @if (availableJobRoles.Any())
                    {
                        <div class="role-chip-row">
                            @foreach (var role in availableJobRoles)
                            {
                                <label class="role-chip @(newJobRoles.Contains(role) ? "role-chip--active" : "")">
                                    <input type="checkbox" id="role_@role" checked="@newJobRoles.Contains(role)" @onchange="@(e => ToggleJobRole(e, role))" />
                                    @role
                                </label>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="form-text mb-0">No job roles configured yet. Set them up in <strong>Weekly Preferences</strong>.</p>
                    }
                </div>

                <div class="form-info-note">
                    Daily availability will be initialised from <strong>Working days</strong>. You can refine it per-day from the staff list.
                </div>

                <div class="form-action-row">
                    <button class="btn btn-primary" @onclick="SaveStaff">Save staff member</button>
                    <button class="btn btn-ghost" @onclick="CancelAddStaff">Cancel</button>
                </div>
            </div>
        </section>
    }

    <section class="staff-list-section card">
        <div class="card-body">
            <div class="section-title-row">
                <h2>Current staff</h2>
                <span class="staff-count-badge">@staffList.Count staff</span>
            </div>

            @if (!staffList.Any())
            {
                <div class="empty-state">
                    <svg class="empty-state-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="24" cy="18" r="8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                        <path d="M8 40c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                    <p class="empty-state-title">No staff members yet</p>
                    <p class="empty-state-body">Select <strong>Add staff</strong> above to create your first team member.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="staff-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Roles</th>
                                <th>Available days</th>
                                <th>Pref. days</th>
                                <th>Hourly wage</th>
                                <th>This week</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var staff in staffList)
                            {
                                <tr>
                                    <td>
                                        <span class="staff-name">@staff.NewStaffName</span>
                                        @if (staff.IsManager)
                                        {
                                            <span class="role-pill role-pill--manager">Manager</span>
                                        }
                                    </td>
                                    <td>
                                        @if (staff.JobRoles.Any())
                                        {
                                            <div class="pill-list">
                                                @foreach (var role in staff.JobRoles)
                                                {
                                                    <span class="role-pill">@role</span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var availableDays = staff.DailyAvailability
                                                .Where(x => x.Value)
                                                .Select(x => GetDayAbbreviation(x.Key))
                                                .ToList();
                                        }
                                        @if (availableDays.Any())
                                        {
                                            <span class="day-pill">@string.Join(" · ", availableDays)</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">None</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="stat-value">@GetPreferredDaysDisplay(staff)</span>
                                    </td>
                                    <td>
                                        <span class="wage-value">@FormatHourlyWage(staff.HourlyWage)</span>
                                    </td>
                                    <td>
                                        <label class="toggle-switch" title="Toggle availability this week">
                                            <input type="checkbox" checked="@staff.IsAvailableThisWeek" @onchange="@(e => ToggleAvailability(e, staff))" />
                                            <span class="toggle-track"></span>
                                        </label>
                                    </td>
                                    <td>
                                        <div class="action-group">
                                            <button class="btn-action" title="Edit availability" @onclick="@(() => ShowEditAvailability(staff))">
                                                <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 11L11.5 1.5a1.414 1.414 0 012 2L5 13H2v-2z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                                Days
                                            </button>
                                            <button class="btn-action" title="Edit staff details" @onclick="@(() => ShowEditStaffDetails(staff))">
                                                <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M2 14c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                                                Edit
                                            </button>
                                            <button class="btn-action btn-action--danger" title="Delete staff member" @onclick="@(() => DeleteStaffWithConfirmation(staff))">
                                                <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 4h12M6 4V2h4v2M5 4v9a1 1 0 001 1h4a1 1 0 001-1V4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

@if (showEditAvailability && editingStaff != null)
{
    <div class="modal d-block staff-modal-backdrop" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content staff-modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Weekly Availability - @editingStaff.NewStaffName</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditAvailability"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <button type="button" class="btn btn-sm btn-outline-secondary me-2" @onclick="SetEditDaysAllAvailable">Set All Days</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearEditDays">Clear All Days</button>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var day in WeekDays)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="edit_avail_@day" checked="@editingStaff.DailyAvailability[day]" @onchange="@(e => ToggleEditDayAvailability(e, day))" />
                                <label class="form-check-label" for="edit_avail_@day">@day</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseEditAvailability">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveEditAvailability">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showEditStaffDetails && staffDetailsToEdit != null)
{
    <div class="modal d-block staff-modal-backdrop" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content staff-modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Staff Details - @staffDetailsToEdit.NewStaffName</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditStaffDetails"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Staff Name</label>
                        <input class="form-control" @bind="editStaffName" />
                    </div>

                    <div class="d-flex flex-wrap gap-3 mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="editIsManager" @bind="editIsManager" />
                            <label class="form-check-label" for="editIsManager">Manager</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="editIsActive" @bind="editIsActive" />
                            <label class="form-check-label" for="editIsActive">Active staff member</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="editIsAvailableThisWeek" @bind="editIsAvailableThisWeek" />
                            <label class="form-check-label" for="editIsAvailableThisWeek">Available this week</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Working Days</label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var day in WeekDays)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="edit_day_@day" checked="@editWorkingDays.Contains(day)" @onchange="@(e => ToggleEditWorkingDay(e, day))" />
                                    <label class="form-check-label" for="edit_day_@day">@day</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Preferred days per week</label>
                        <input class="form-control" type="number" min="0" max="7" @bind="editPreferredDaysPerWeek" />
                        <div class="form-text">This helps the rota balance full-time and part-time hours more fairly.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Hourly Wage</label>
                        <input class="form-control" type="number" min="0" step="0.01" @bind="editHourlyWage" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Start Time</label>
                            @if (availableStartTimes.Any())
                            {
                                <select class="form-select" @bind="editStartTime">
                                    <option value="">Select a start time</option>
                                    @if (!string.IsNullOrWhiteSpace(editStartTime) && !availableStartTimes.Contains(editStartTime))
                                    {
                                        <option value="@editStartTime">@editStartTime (current)</option>
                                    }
                                    @foreach (var time in availableStartTimes)
                                    {
                                        <option value="@time">@time</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input class="form-control" type="time" value="@editStartTime" @onchange="OnEditStartTimeChanged" />
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">End Time</label>
                            @if (availableEndTimes.Any())
                            {
                                <select class="form-select" @bind="editEndTime">
                                    <option value="">Select an end time</option>
                                    @if (!string.IsNullOrWhiteSpace(editEndTime) && !availableEndTimes.Contains(editEndTime))
                                    {
                                        <option value="@editEndTime">@editEndTime (current)</option>
                                    }
                                    @foreach (var time in availableEndTimes)
                                    {
                                        <option value="@time">@time</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input class="form-control" type="time" value="@editEndTime" @onchange="OnEditEndTimeChanged" />
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Job Roles</label>
                        @if (availableJobRoles.Any())
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var role in availableJobRoles)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="edit_role_@role" checked="@editJobRoles.Contains(role)" @onchange="@(e => ToggleEditJobRole(e, role))" />
                                        <label class="form-check-label" for="edit_role_@role">@role</label>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="form-text">No job roles configured yet. Configure them in Weekly Preferences.</div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseEditStaffDetails">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveEditStaffDetails">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

</div>

@code 
{
    private bool showInput = false;
    private string newStaffName = "";

    private decimal newHourlyWage = 0;
    private bool newIsManager = false;
    private string newStartTime = "";

    private string newEndTime = "";
    private int newPreferredDaysPerWeek = 0;

    private List<string> newWorkingDays = new();
    private List<string> newJobRoles = new();
    private Dictionary<string, bool> newDailyAvailability = new()
    {
        { "Monday", false },
        { "Tuesday", false },
        { "Wednesday", false },
        { "Thursday", false },
        { "Friday", false },
        { "Saturday", false },
        { "Sunday", false }
    };
    private List<StaffInput> staffList = new();
    private StartTimeRequirements weeklyStartTimes = new();
    private List<string> availableStartTimes = new();
    
    private EndTimeRequirements weeklyEndTimes = new();

    private List<string> availableEndTimes = new();
    private JobRoleRequirements weeklyJobRoles = new();
    private List<string> availableJobRoles = new();

    private bool showEditAvailability = false;
    private StaffInput? editingStaff = null;
    private bool showEditStaffDetails = false;
    private StaffInput? staffDetailsToEdit = null;
    private string editStaffName = string.Empty;
    private bool editIsManager = false;
    private bool editIsActive = true;
    private bool editIsAvailableThisWeek = false;
    private int editPreferredDaysPerWeek = 0;
    private string editStartTime = string.Empty;
    private string editEndTime = string.Empty;
    private decimal editHourlyWage = 0;
    private List<string> editWorkingDays = new();
    private List<string> editJobRoles = new();
    private string statusMessage = string.Empty;

    private readonly string[] WeekDays = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };

    void ShowInput()
    {
        ResetNewStaffForm();
        showInput = true;
        StateHasChanged();
    }

    void CancelAddStaff()
    {
        showInput = false;
        ResetNewStaffForm();
    }

    void ResetNewStaffForm()
    {
        newStaffName = string.Empty;
        newIsManager = false;
        newStartTime = string.Empty;
        newEndTime = string.Empty;
        newHourlyWage = 0;
        newPreferredDaysPerWeek = 0;
        newWorkingDays.Clear();
        newJobRoles.Clear();
        foreach (var day in WeekDays)
        {
            newDailyAvailability[day] = false;
        }
    }

    async Task SaveStaff()
    {
        if (!string.IsNullOrWhiteSpace(newStaffName))
        {
            var initialDailyAvailability = BuildDailyAvailabilityFromWorkingDays();

            var newStaff = new StaffInput
            {
                EmployeeID = Guid.NewGuid().ToString(),
                NewStaffName = newStaffName.Trim(),
                LastNameInitial = string.Empty,
                IsManager = newIsManager,
                WorkingDays = string.Join(", ", newWorkingDays),
                StartTime = newStartTime,
                EndTime = newEndTime,
                IsActive = true,
                HourlyWage = NormalizeHourlyWage(newHourlyWage),
                IsAvailableThisWeek = initialDailyAvailability.Any(x => x.Value),
                PreferredDaysPerWeek = NormalizePreferredDaysPerWeek(newPreferredDaysPerWeek, newWorkingDays.Count),
                JobRoles = newJobRoles.ToList(),
                DailyAvailability = initialDailyAvailability
            };

            staffList.Add(newStaff);
            await SaveStaffListAsync();
            statusMessage = $"{newStaff.NewStaffName} added to the staff list.";
            ResetNewStaffForm();
            showInput = false;
        }
    }

    Dictionary<string, bool> BuildDailyAvailabilityFromWorkingDays()
    {
        return WeekDays.ToDictionary(day => day, day => newWorkingDays.Contains(day));
    }

    void ToggleDay(ChangeEventArgs e, string day)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        if (isChecked)
        {
            if (!newWorkingDays.Contains(day))
            {
                newWorkingDays.Add(day);
            }
        }
        else
        {
            newWorkingDays.Remove(day);
        }

        newDailyAvailability[day] = isChecked;
    }

    void ToggleJobRole(ChangeEventArgs e, string role)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        if (isChecked)
        {
            if (!newJobRoles.Contains(role))
            {
                newJobRoles.Add(role);
            }
        }
        else
        {
            newJobRoles.Remove(role);
        }
    }

    void ToggleDayAvailability(ChangeEventArgs e, string day)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        newDailyAvailability[day] = isChecked;
    }

    void SetAllDaysAvailable()
    {
        foreach (var day in WeekDays)
        {
            newDailyAvailability[day] = true;
        }
        StateHasChanged();
    }

    void ClearAllDays()
    {
        foreach (var day in WeekDays)
        {
            newDailyAvailability[day] = false;
        }
        StateHasChanged();
    }

    void ShowEditAvailability(StaffInput staff)
    {
        editingStaff = staff;
        showEditAvailability = true;
        StateHasChanged();
    }

    void CloseEditAvailability()
    {
        showEditAvailability = false;
        editingStaff = null;
        StateHasChanged();
    }

    void ToggleEditDayAvailability(ChangeEventArgs e, string day)
    {
        if (editingStaff != null)
        {
            var isChecked = e?.Value is bool boolValue && boolValue
                || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

            editingStaff.DailyAvailability[day] = isChecked;
        }
    }

    void SetEditDaysAllAvailable()
    {
        if (editingStaff != null)
        {
            foreach (var day in WeekDays)
            {
                editingStaff.DailyAvailability[day] = true;
            }
            StateHasChanged();
        }
    }

    void ClearEditDays()
    {
        if (editingStaff != null)
        {
            foreach (var day in WeekDays)
            {
                editingStaff.DailyAvailability[day] = false;
            }
            StateHasChanged();
        }
    }

    async Task SaveEditAvailability()
    {
        await SaveStaffListAsync();
        statusMessage = $"Availability updated for {editingStaff?.NewStaffName}.";
        CloseEditAvailability();
    }

    void ShowEditStaffDetails(StaffInput staff)
    {
        staffDetailsToEdit = staff;
        editStaffName = staff.NewStaffName;
        editIsManager = staff.IsManager;
        editIsActive = staff.IsActive;
        editIsAvailableThisWeek = staff.IsAvailableThisWeek;
        editPreferredDaysPerWeek = GetEffectivePreferredDaysPerWeek(staff);
        editStartTime = staff.StartTime;
        editEndTime = staff.EndTime;
        editHourlyWage = staff.HourlyWage;
        editWorkingDays = staff.WorkingDays
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        editJobRoles = staff.JobRoles
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        showEditStaffDetails = true;
        StateHasChanged();
    }

    void CloseEditStaffDetails()
    {
        showEditStaffDetails = false;
        staffDetailsToEdit = null;
        editStaffName = string.Empty;
        editIsManager = false;
        editIsActive = true;
        editIsAvailableThisWeek = false;
        editPreferredDaysPerWeek = 0;
        editStartTime = string.Empty;
        editEndTime = string.Empty;
        editHourlyWage = 0;
        editWorkingDays.Clear();
        editJobRoles.Clear();
        StateHasChanged();
    }

    void ToggleEditWorkingDay(ChangeEventArgs e, string day)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        if (isChecked)
        {
            if (!editWorkingDays.Contains(day))
            {
                editWorkingDays.Add(day);
            }
        }
        else
        {
            editWorkingDays.Remove(day);
        }
    }

    void ToggleEditJobRole(ChangeEventArgs e, string role)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        if (isChecked)
        {
            if (!editJobRoles.Contains(role))
            {
                editJobRoles.Add(role);
            }
        }
        else
        {
            editJobRoles.Remove(role);
        }
    }

    async Task SaveEditStaffDetails()
    {
        if (staffDetailsToEdit == null || string.IsNullOrWhiteSpace(editStaffName))
        {
            return;
        }

        var updatedName = editStaffName.Trim();
        staffDetailsToEdit.NewStaffName = updatedName;
        staffDetailsToEdit.IsManager = editIsManager;
        staffDetailsToEdit.IsActive = editIsActive;
        staffDetailsToEdit.PreferredDaysPerWeek = NormalizePreferredDaysPerWeek(editPreferredDaysPerWeek, editWorkingDays.Count);
        staffDetailsToEdit.StartTime = editStartTime;
        staffDetailsToEdit.EndTime = editEndTime;
        staffDetailsToEdit.HourlyWage = NormalizeHourlyWage(editHourlyWage);
        staffDetailsToEdit.JobRoles = editJobRoles
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var updatedAvailability = BuildEditedDailyAvailability(staffDetailsToEdit);
        staffDetailsToEdit.WorkingDays = string.Join(", ", editWorkingDays);

        if (!editIsActive || !editIsAvailableThisWeek)
        {
            updatedAvailability = WeekDays.ToDictionary(day => day, _ => false);
            staffDetailsToEdit.IsAvailableThisWeek = false;
        }
        else
        {
            staffDetailsToEdit.IsAvailableThisWeek = updatedAvailability.Any(x => x.Value);
        }

        staffDetailsToEdit.DailyAvailability = updatedAvailability;

        await SaveStaffListAsync();
        statusMessage = $"{updatedName} updated successfully.";
        CloseEditStaffDetails();
    }

    Dictionary<string, bool> BuildEditedDailyAvailability(StaffInput staff)
    {
        var selectedDays = editWorkingDays.ToHashSet(StringComparer.OrdinalIgnoreCase);
        var previousWorkingDays = staff.WorkingDays
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return WeekDays.ToDictionary(
            day => day,
            day =>
            {
                if (!selectedDays.Contains(day))
                {
                    return false;
                }

                if (!previousWorkingDays.Contains(day))
                {
                    return true;
                }

                return staff.DailyAvailability.TryGetValue(day, out var isAvailable) ? isAvailable : true;
            });
    }

    private int GetEffectivePreferredDaysPerWeek(StaffInput staff)
    {
        var availableDaysCount = staff.DailyAvailability?.Count(x => x.Value) ?? 0;

        if (availableDaysCount == 0 && !string.IsNullOrWhiteSpace(staff.WorkingDays))
        {
            availableDaysCount = staff.WorkingDays
                .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Count();
        }

        if (staff.PreferredDaysPerWeek <= 0)
        {
            return availableDaysCount;
        }

        return availableDaysCount > 0
            ? Math.Min(staff.PreferredDaysPerWeek, availableDaysCount)
            : staff.PreferredDaysPerWeek;
    }

    private static int NormalizePreferredDaysPerWeek(int preferredDays, int availableDaysCount)
    {
        var normalized = Math.Max(0, preferredDays);
        if (availableDaysCount <= 0)
        {
            return normalized;
        }

        return normalized == 0
            ? availableDaysCount
            : Math.Min(normalized, availableDaysCount);
    }

    private static decimal NormalizeHourlyWage(decimal hourlyWage)
    {
        return Math.Max(0, decimal.Round(hourlyWage, 2));
    }

    private string GetPreferredDaysDisplay(StaffInput staff)
    {
        var effectiveDays = GetEffectivePreferredDaysPerWeek(staff);
        return effectiveDays > 0 ? $"{effectiveDays} / week" : "Not set";
    }

    private static string FormatHourlyWage(decimal hourlyWage)
    {
        return hourlyWage > 0 ? $"£{hourlyWage:0.00}" : "Not set";
    }

