@page "/weeklyPrefs"
@rendermode InteractiveServer
@using DayRequirements.Models
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<PageTitle>Weekly Preferences</PageTitle>
<h1>Weekly Preferences</h1>
<p>Here you can set the weekly preferences for staff coverage and define the four start-time slots that are available when adding a new staff member.</p>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Staff required per day</h2>
                <div class="mb-3">
                    <label class="form-label" for="monday">Monday</label>
                    <input id="monday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Monday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="tuesday">Tuesday</label>
                    <input id="tuesday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Tuesday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="wednesday">Wednesday</label>
                    <input id="wednesday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Wednesday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="thursday">Thursday</label>
                    <input id="thursday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Thursday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="friday">Friday</label>
                    <input id="friday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Friday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="saturday">Saturday</label>
                    <input id="saturday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Saturday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="sunday">Sunday</label>
                    <input id="sunday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Sunday" />
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Available start times</h2>
                <p class="text-muted">Add or remove start-time slots that will appear as options in the staff add form.</p>
                @if (weeklyStartTimes.StartTimes.Any())
                {
                    @foreach (var (time, index) in weeklyStartTimes.StartTimes.Select((t, i) => (t, i)))
                    {
                        <div class="input-group mb-2">
                            <input type="time" class="form-control" @bind="weeklyStartTimes.StartTimes[index]" />
                            <button class="btn btn-outline-danger" type="button" @onclick="@(() => RemoveStartTime(index))">Remove</button>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No start times added yet.</p>
                }
                <button class="btn btn-secondary" @onclick="AddStartTime">Add start time</button>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Available end times</h2>
                <p class="text-muted">Add or remove end-time slots that will appear as options in the staff add form.</p>
                @if (weeklyEndTimes.EndTimes.Any())
                {
                    @foreach (var (time, index) in weeklyEndTimes.EndTimes.Select((t, i) => (t, i)))
                    {
                        <div class="input-group mb-2">
                            <input type="time" class="form-control" @bind="weeklyEndTimes.EndTimes[index]" />
                            <button class="btn btn-outline-danger" type="button" @onclick="@(() => RemoveEndTime(index))">Remove</button>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No end times added yet.</p>
                }
                <button class="btn btn-secondary" @onclick="AddEndTime">Add end time</button>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Available job roles</h2>
                <p class="text-muted">Add or remove job roles that staff members can be assigned to.</p>
                @if (weeklyJobRoles.JobRoles.Any())
                {
                    @foreach (var (role, index) in weeklyJobRoles.JobRoles.Select((r, i) => (r, i)))
                    {
                        <div class="input-group mb-2">
                            <input type="text" class="form-control" placeholder="Job Role" @bind="weeklyJobRoles.JobRoles[index]" />
                            <button class="btn btn-outline-danger" type="button" @onclick="@(() => RemoveJobRole(index))">Remove</button>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No job roles added yet.</p>
                }
                <button class="btn btn-secondary" @onclick="AddJobRole">Add job role</button>
            </div>
        </div>
    </div>
</div>

<button class="btn btn-primary" @onclick="SaveWeeklyPrefs">Save preferences</button>
@if (!string.IsNullOrWhiteSpace(saveMessage))
{
    <div class="alert alert-success mt-3" role="alert">@saveMessage</div>
}

@code {
    private DayRequirements weeklyRequirements = new DayRequirements
    {
        Monday = 0,
        Tuesday = 0,
        Wednesday = 0,
        Thursday = 0,
        Friday = 0,
        Saturday = 0,
        Sunday = 0
    };
    private StartTimeRequirements weeklyStartTimes = new StartTimeRequirements();
    private EndTimeRequirements weeklyEndTimes = new EndTimeRequirements();
    private JobRoleRequirements weeklyJobRoles = new JobRoleRequirements();
    private string saveMessage = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedDayRequirements = await localStorage.GetItemAsync<DayRequirements>("weeklyDayRequirements");
            if (savedDayRequirements != null)
            {
                weeklyRequirements = savedDayRequirements;
            }

            var savedStartTimes = await localStorage.GetItemAsync<StartTimeRequirements>("startTimeRequirements");
            if (savedStartTimes != null)
            {
                weeklyStartTimes = savedStartTimes;
            }

            var savedEndTimes = await localStorage.GetItemAsync<EndTimeRequirements>("endTimeRequirements");
            if (savedEndTimes != null)            
            {
                weeklyEndTimes = savedEndTimes;
            }

            var savedJobRoles = await localStorage.GetItemAsync<JobRoleRequirements>("jobRoleRequirements");
            if (savedJobRoles != null)
            {
                weeklyJobRoles = savedJobRoles;
            }

            StateHasChanged();
        }
    }

    async Task SaveWeeklyPrefs()
    {
        await localStorage.SetItemAsync("weeklyDayRequirements", weeklyRequirements);
        await localStorage.SetItemAsync("startTimeRequirements", weeklyStartTimes);
        await localStorage.SetItemAsync("endTimeRequirements", weeklyEndTimes);
        await localStorage.SetItemAsync("jobRoleRequirements", weeklyJobRoles);
        saveMessage = "Weekly preferences saved locally.";
    }

    void AddStartTime()
    {
        weeklyStartTimes.StartTimes.Add(new TimeOnly(9, 0));
    }

    void AddEndTime()
    {
        weeklyEndTimes.EndTimes.Add(new TimeOnly(17, 0));
    }

    void AddJobRole()
    {
        weeklyJobRoles.JobRoles.Add("New Role");
    }

    void RemoveStartTime(int index)
    {
        if (index >= 0 && index < weeklyStartTimes.StartTimes.Count)
        {
            weeklyStartTimes.StartTimes.RemoveAt(index);
        }
    }

    void RemoveEndTime(int index)
    {
        if (index >= 0 && index < weeklyEndTimes.EndTimes.Count)
        {
            weeklyEndTimes.EndTimes.RemoveAt(index);
        }
    }

    void RemoveJobRole(int index)
    {
        if (index >= 0 && index < weeklyJobRoles.JobRoles.Count)
        {
            weeklyJobRoles.JobRoles.RemoveAt(index);
        }
    }

    private static string FormatTime(TimeOnly? time)
    {
        return time.HasValue ? time.Value.ToString("HH:mm") : "Unset";
    }
}
