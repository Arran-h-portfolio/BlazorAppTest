@page "/weeklyPrefs"
@using DayRequirements.Models
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<PageTitle>Weekly Preferences</PageTitle>
<div class="weekly-prefs-page">

    <header class="prefs-hero card">
        <div class="prefs-hero-body">
            <div class="prefs-hero-text">
                <h1>Weekly Preferences</h1>
                <p>Adjust staffing targets, shift options, daily coverage, and role requirements for the week.</p>
            </div>
            <div class="prefs-kpis">
                <div class="prefs-kpi">
                    <span class="kpi-label">Total staff needed</span>
                    <strong class="kpi-value">@TotalWeeklyStaffRequired</strong>
                </div>
                <div class="prefs-kpi">
                    <span class="kpi-label">Start slots</span>
                    <strong class="kpi-value">@weeklyStartTimes.StartTimes.Count</strong>
                </div>
                <div class="prefs-kpi">
                    <span class="kpi-label">End slots</span>
                    <strong class="kpi-value">@weeklyEndTimes.EndTimes.Count</strong>
                </div>
                <div class="prefs-kpi">
                    <span class="kpi-label">Job roles</span>
                    <strong class="kpi-value">@weeklyJobRoles.JobRoles.Count</strong>
                </div>
            </div>
        </div>
    </header>

    @* ── Staff per day ──────────────────────────────────────── *@
    <section class="prefs-card card">
        <div class="card-body">
            <div class="card-section-header">
                <h2>Staff required per day</h2>
                <p class="section-desc">Set the baseline daily headcount used when generating the rota.</p>
            </div>
            <div class="day-strip">
                <div class="day-strip-item">
                    <span class="day-strip-label">Mon</span>
                    <input class="form-control day-strip-input" type="number" min="0" @bind="weeklyRequirements.Monday" />
                </div>
                <div class="day-strip-item">
                    <span class="day-strip-label">Tue</span>
                    <input class="form-control day-strip-input" type="number" min="0" @bind="weeklyRequirements.Tuesday" />
                </div>
                <div class="day-strip-item">
                    <span class="day-strip-label">Wed</span>
                    <input class="form-control day-strip-input" type="number" min="0" @bind="weeklyRequirements.Wednesday" />
                </div>
                <div class="day-strip-item">
                    <span class="day-strip-label">Thu</span>
                    <input class="form-control day-strip-input" type="number" min="0" @bind="weeklyRequirements.Thursday" />
                </div>
                <div class="day-strip-item">
                    <span class="day-strip-label">Fri</span>
                    <input class="form-control day-strip-input" type="number" min="0" @bind="weeklyRequirements.Friday" />
                </div>
                <div class="day-strip-item">
                    <span class="day-strip-label">Sat</span>
                    <input class="form-control day-strip-input" type="number" min="0" @bind="weeklyRequirements.Saturday" />
                </div>
                <div class="day-strip-item">
                    <span class="day-strip-label">Sun</span>
                    <input class="form-control day-strip-input" type="number" min="0" @bind="weeklyRequirements.Sunday" />
                </div>
            </div>
        </div>
    </section>

    @* ── Rota failsafes ─────────────────────────────────────── *@
    <section class="prefs-card card">
        <div class="card-body">
            <div class="card-section-header">
                <h2>Rota FailSafes</h2>
                <p class="section-desc">Guardrails to keep schedules practical when availability is tight.</p>
            </div>
            <label class="setting-row">
                <div class="setting-row-text">
                    <span class="setting-row-title">Always schedule a manager first</span>
                    <span class="setting-row-desc">Each staffed day will start with a manager wherever one is available.</span>
                </div>
                <div class="toggle-switch">
                    <input type="checkbox" id="managerFirst" @bind="rotaGenerationOptions.AlwaysScheduleManagerFirst" />
                    <span class="toggle-track"></span>
                </div>
            </label>
        </div>
    </section>

    @* ── Shift time options ─────────────────────────────────── *@
    <section class="prefs-card card">
        <div class="card-body">
            <div class="card-section-header">
                <h2>Shift time options</h2>
                <p class="section-desc">Reusable start and end times shown when creating or editing staff profiles.</p>
            </div>
            <div class="time-columns">
                <div class="time-col">
                    <h3 class="col-subheading">Start times</h3>
                    @if (weeklyStartTimes.StartTimes.Any())
                    {
                        <div class="time-slot-list">
                            @foreach (var (time, index) in weeklyStartTimes.StartTimes.Select((t, i) => (t, i)))
                            {
                                <div class="time-slot-row">
                                    <input type="time" class="form-control" @bind="weeklyStartTimes.StartTimes[index]" />
                                    <button class="btn-remove" type="button" title="Remove" @onclick="@(() => RemoveStartTime(index))">
                                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 4h12M6 4V2h4v2M5 4v9a1 1 0 001 1h4a1 1 0 001-1V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty-inline">No start times yet.</p>
                    }
                    <button class="btn-add-item" @onclick="AddStartTime">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                        Add start time
                    </button>
                </div>

                <div class="time-col">
                    <h3 class="col-subheading">End times</h3>
                    @if (weeklyEndTimes.EndTimes.Any())
                    {
                        <div class="time-slot-list">
                            @foreach (var (time, index) in weeklyEndTimes.EndTimes.Select((t, i) => (t, i)))
                            {
                                <div class="time-slot-row">
                                    <input type="time" class="form-control" @bind="weeklyEndTimes.EndTimes[index]" />
                                    <button class="btn-remove" type="button" title="Remove" @onclick="@(() => RemoveEndTime(index))">
                                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 4h12M6 4V2h4v2M5 4v9a1 1 0 001 1h4a1 1 0 001-1V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty-inline">No end times yet.</p>
                    }
                    <button class="btn-add-item" @onclick="AddEndTime">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                        Add end time
                    </button>
                </div>
            </div>
        </div>
    </section>

    @* ── Opening and coverage targets ───────────────────────── *@
    <section class="prefs-card card">
        <div class="card-body">
            <div class="card-section-header">
                <h2>Opening and coverage targets</h2>
                <p class="section-desc">Set opening times and minimum staffing-by-time targets for each day.</p>
            </div>
            <div class="coverage-table">
                <div class="coverage-header">
                    <span>Day</span>
                    <span>Opening time</span>
                    <span>Min. staff needed</span>
                    <span>All in by</span>
                </div>
                @foreach (var day in WeekDays)
                {
                    <div class="coverage-row">
                        <span class="day-badge">@day.Substring(0, 3)</span>
                        <input type="time" class="form-control" @bind="dailyOpeningTimes.StartTimesByDay[day]" />
                        <input type="number" min="0" class="form-control" @bind="dailyCoverageTargets.CoverageByDay[day].RequiredStaff" />
                        <input type="time" class="form-control" @bind="dailyCoverageTargets.CoverageByDay[day].RequiredByTime" />
                    </div>
                }
            </div>
        </div>
    </section>

    @* ── Job roles and daily requirements ───────────────────── *@
    <section class="prefs-card card">
        <div class="card-body">
            <div class="card-section-header">
                <h2>Job roles and daily requirements</h2>
                <p class="section-desc">Manage role options and assign which roles are required for each day.</p>
            </div>
            <div class="roles-layout">
                <div class="roles-bank">
                    <h3 class="col-subheading">Available job roles</h3>
                    @if (weeklyJobRoles.JobRoles.Any())
                    {
                        <div class="role-input-list">
                            @foreach (var (role, index) in weeklyJobRoles.JobRoles.Select((r, i) => (r, i)))
                            {
                                <div class="time-slot-row">
                                    <input type="text" class="form-control" placeholder="Role name" @bind="weeklyJobRoles.JobRoles[index]" />
                                    <button class="btn-remove" type="button" title="Remove" @onclick="@(() => RemoveJobRole(index))">
                                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 4h12M6 4V2h4v2M5 4v9a1 1 0 001 1h4a1 1 0 001-1V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty-inline">No roles yet. Add one to configure daily assignments.</p>
                    }
                    <button class="btn-add-item" @onclick="AddJobRole">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                        Add job role
                    </button>
                </div>

                <div class="roles-by-day">
                    <h3 class="col-subheading">Daily role requirements</h3>
                    @foreach (var day in WeekDays)
                    {
                        <div class="day-role-panel">
                            <div class="day-role-header">
                                <span class="day-badge">@day.Substring(0, 3)</span>
                                <span class="day-full-name">@day</span>
                                @if (weeklyJobRoles.JobRoles.Any())
                                {
                                    <label class="select-all-label">
                                        <input class="form-check-input" type="checkbox" checked="@AreAllJobRolesSelected(day)" @onchange="@(e => ToggleAllDayJobRoles(e, day))" />
                                        All roles
                                    </label>
                                }
                            </div>
                            @if (weeklyJobRoles.JobRoles.Any())
                            {
                                <div class="role-chips">
                                    @foreach (var role in weeklyJobRoles.JobRoles)
                                    {
                                        <label class="role-chip @(dailyJobRoles.JobRolesByDay[day].Contains(role) ? "role-chip--active" : "")" for="@($"dayrole_{day}_{role}")">
                                            <input type="checkbox" id="@($"dayrole_{day}_{role}")" checked="@dailyJobRoles.JobRolesByDay[day].Contains(role)" @onchange="@(e => ToggleDayJobRole(e, day, role))" />
                                            @role
                                        </label>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="empty-inline">No roles configured yet.</p>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @* ── Save action ────────────────────────────────────────── *@
    <div class="prefs-actions">
        <button class="btn btn-primary" @onclick="SaveWeeklyPrefs">Save weekly preferences</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(saveMessage))
    {
        <div class="alert @saveMessageCssClass save-alert" role="alert">@saveMessage</div>
    }
</div>

@code {
    private DayRequirements weeklyRequirements = new DayRequirements
    {
        Monday = 0,
        Tuesday = 0,
        Wednesday = 0,
        Thursday = 0,
        Friday = 0,
        Saturday = 0,
        Sunday = 0
    };
    private StartTimeRequirements weeklyStartTimes = new StartTimeRequirements();
    private EndTimeRequirements weeklyEndTimes = new EndTimeRequirements();
    private JobRoleRequirements weeklyJobRoles = new JobRoleRequirements();
    private DaySpecificStartTimes dailyOpeningTimes = new DaySpecificStartTimes();
    private DaySpecificCoverageRequirements dailyCoverageTargets = new DaySpecificCoverageRequirements();
    private RotaGenerationOptions rotaGenerationOptions = new RotaGenerationOptions();
    private DaySpecificJobRoles dailyJobRoles = new DaySpecificJobRoles();
    private string saveMessage = string.Empty;
    private string saveMessageCssClass = "alert-success";
    private readonly string[] WeekDays = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    private int TotalWeeklyStaffRequired => weeklyRequirements.Monday
        + weeklyRequirements.Tuesday
        + weeklyRequirements.Wednesday
        + weeklyRequirements.Thursday
        + weeklyRequirements.Friday
        + weeklyRequirements.Saturday
        + weeklyRequirements.Sunday;

    @* Below states trying local storage for all saved constraints first *@

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedDayRequirements = await localStorage.GetItemAsync<DayRequirements>("weeklyDayRequirements");
                if (savedDayRequirements != null)
                {
                    weeklyRequirements = savedDayRequirements;
                }

                var savedStartTimes = await localStorage.GetItemAsync<StartTimeRequirements>("startTimeRequirements");
                if (savedStartTimes != null)
                {
                    weeklyStartTimes = savedStartTimes;
                }

                var savedEndTimes = await localStorage.GetItemAsync<EndTimeRequirements>("endTimeRequirements");
                if (savedEndTimes != null)
                {
                    weeklyEndTimes = savedEndTimes;
                }

                var savedJobRoles = await localStorage.GetItemAsync<JobRoleRequirements>("jobRoleRequirements");
                if (savedJobRoles != null)
                {
                    weeklyJobRoles = savedJobRoles;
                }

                var savedDailyOpeningTimes = await localStorage.GetItemAsync<DaySpecificStartTimes>("daySpecificStartTimes");
                if (savedDailyOpeningTimes != null)
                {
                    dailyOpeningTimes = savedDailyOpeningTimes;
                }

                var savedDailyCoverageTargets = await localStorage.GetItemAsync<DaySpecificCoverageRequirements>("daySpecificCoverageRequirements");
                if (savedDailyCoverageTargets != null)
                {
                    dailyCoverageTargets = savedDailyCoverageTargets;
                }

                var savedRotaGenerationOptions = await localStorage.GetItemAsync<RotaGenerationOptions>("rotaGenerationOptions");
                if (savedRotaGenerationOptions != null)
                {
                    rotaGenerationOptions = savedRotaGenerationOptions;
                }

                var savedDailyJobRoles = await localStorage.GetItemAsync<DaySpecificJobRoles>("daySpecificJobRoles");
                if (savedDailyJobRoles != null)
                {
                    dailyJobRoles = savedDailyJobRoles;
                }

                EnsurePreferenceData();
            }
            catch (Exception ex)
            {
                EnsurePreferenceData();
                saveMessageCssClass = "alert-warning";
                saveMessage = $"Saved preferences couldn't be fully loaded, so safe defaults were used. ({ex.Message})";
            }

            StateHasChanged();
        }
    }

    @* Below saves all the weekly preferences and constraints *@

    async Task SaveWeeklyPrefs()
    {
        try
        {
            EnsurePreferenceData();
            await localStorage.SetItemAsync("weeklyDayRequirements", weeklyRequirements);
            await localStorage.SetItemAsync("startTimeRequirements", weeklyStartTimes);
            await localStorage.SetItemAsync("endTimeRequirements", weeklyEndTimes);
            await localStorage.SetItemAsync("jobRoleRequirements", weeklyJobRoles);
            await localStorage.SetItemAsync("daySpecificStartTimes", dailyOpeningTimes);
            await localStorage.SetItemAsync("daySpecificCoverageRequirements", dailyCoverageTargets);
            await localStorage.SetItemAsync("rotaGenerationOptions", rotaGenerationOptions);
            await localStorage.SetItemAsync("daySpecificJobRoles", dailyJobRoles);
            saveMessageCssClass = "alert-success";
            saveMessage = "Weekly preferences saved locally.";
        }
        catch (Exception ex)
        {
            saveMessageCssClass = "alert-danger";
            saveMessage = $"Unable to save weekly preferences: {ex.Message}";
        }
    }

    void AddStartTime()
    {
        weeklyStartTimes.StartTimes.Add(new TimeOnly(9, 0));
    }

    void AddEndTime()
    {
        weeklyEndTimes.EndTimes.Add(new TimeOnly(17, 0));
    }

    void AddJobRole()
    {
        weeklyJobRoles.JobRoles.Add("New Role");
    }

    void RemoveStartTime(int index)
    {
        if (index >= 0 && index < weeklyStartTimes.StartTimes.Count)
        {
            weeklyStartTimes.StartTimes.RemoveAt(index);
        }
    }

    void RemoveEndTime(int index)
    {
        if (index >= 0 && index < weeklyEndTimes.EndTimes.Count)
        {
            weeklyEndTimes.EndTimes.RemoveAt(index);
        }
    }

    void RemoveJobRole(int index)
    {
        if (index >= 0 && index < weeklyJobRoles.JobRoles.Count)
        {
            weeklyJobRoles.JobRoles.RemoveAt(index);
        }
    }

    void ToggleDayJobRole(ChangeEventArgs e, string day, string role)
    {
        EnsureDayJobRolesEntry(day);

        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        if (isChecked)
        {
            if (!dailyJobRoles.JobRolesByDay[day].Contains(role))
            {
                dailyJobRoles.JobRolesByDay[day].Add(role);
            }
        }
        else
        {
            dailyJobRoles.JobRolesByDay[day].Remove(role);
        }
    }

    void ToggleAllDayJobRoles(ChangeEventArgs e, string day)
    {
        EnsureDayJobRolesEntry(day);

        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        dailyJobRoles.JobRolesByDay[day].Clear();

        if (isChecked)
        {
            dailyJobRoles.JobRolesByDay[day].AddRange(weeklyJobRoles.JobRoles.Distinct());
        }
    }

    bool AreAllJobRolesSelected(string day)
    {
        EnsureDayJobRolesEntry(day);

        return weeklyJobRoles.JobRoles.Any()
            && weeklyJobRoles.JobRoles.All(role => dailyJobRoles.JobRolesByDay[day].Contains(role));
    }

    @* BELOW FUNCTION ADDS NEW ITEMS TO LISTS CREATED *@

    private void EnsurePreferenceData()
    {
        weeklyStartTimes ??= new StartTimeRequirements();
        weeklyStartTimes.StartTimes ??= new List<TimeOnly>();

        weeklyEndTimes ??= new EndTimeRequirements();
        weeklyEndTimes.EndTimes ??= new List<TimeOnly>();

        weeklyJobRoles ??= new JobRoleRequirements();
        weeklyJobRoles.JobRoles ??= new List<string>();

        dailyOpeningTimes ??= new DaySpecificStartTimes();
        dailyOpeningTimes.StartTimesByDay ??= new Dictionary<string, TimeOnly>();

        dailyCoverageTargets ??= new DaySpecificCoverageRequirements();
        dailyCoverageTargets.CoverageByDay ??= new Dictionary<string, CoverageRequirement>();

        dailyJobRoles ??= new DaySpecificJobRoles();
        dailyJobRoles.JobRolesByDay ??= new Dictionary<string, List<string>>();

        foreach (var day in WeekDays)
        {
            if (!dailyOpeningTimes.StartTimesByDay.ContainsKey(day))
            {
                dailyOpeningTimes.StartTimesByDay[day] = GetDefaultOpeningTime(day);
            }

            if (!dailyCoverageTargets.CoverageByDay.TryGetValue(day, out var coverageRequirement) || coverageRequirement == null)
            {
                dailyCoverageTargets.CoverageByDay[day] = new CoverageRequirement
                {
                    RequiredStaff = 0,
                    RequiredByTime = GetDefaultOpeningTime(day)
                };
            }
            else if (coverageRequirement.RequiredByTime == default)
            {
                coverageRequirement.RequiredByTime = GetDefaultOpeningTime(day);
            }

            EnsureDayJobRolesEntry(day);
        }
    }

    private void EnsureDayJobRolesEntry(string day)
    {
        dailyJobRoles ??= new DaySpecificJobRoles();
        dailyJobRoles.JobRolesByDay ??= new Dictionary<string, List<string>>();

        if (!dailyJobRoles.JobRolesByDay.TryGetValue(day, out var roles) || roles == null)
        {
            dailyJobRoles.JobRolesByDay[day] = new List<string>();
        }
    }

    private static TimeOnly GetDefaultOpeningTime(string day)
    {
        return day is "Saturday" or "Sunday"
            ? new TimeOnly(10, 0)
            : new TimeOnly(9, 0);
    }

    private static string FormatTime(TimeOnly? time)
    {
        return time.HasValue ? time.Value.ToString("HH:mm") : "Unset";
    }
}
