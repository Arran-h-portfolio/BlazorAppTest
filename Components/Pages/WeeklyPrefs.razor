@page "/weeklyPrefs"
@rendermode InteractiveServer
@using DayRequirements.Models
@inject Blazored.LocalStorage.ILocalStorageService localStorage

<PageTitle>Weekly Preferences</PageTitle>
<h1>Weekly Preferences</h1>
<p>Here you can set daily staffing needs, by-time coverage targets, and the start/end-time options used when adding staff.</p>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Staff required per day</h2>
                <div class="mb-3">
                    <label class="form-label" for="monday">Monday</label>
                    <input id="monday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Monday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="tuesday">Tuesday</label>
                    <input id="tuesday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Tuesday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="wednesday">Wednesday</label>
                    <input id="wednesday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Wednesday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="thursday">Thursday</label>
                    <input id="thursday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Thursday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="friday">Friday</label>
                    <input id="friday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Friday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="saturday">Saturday</label>
                    <input id="saturday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Saturday" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="sunday">Sunday</label>
                    <input id="sunday" class="form-control" type="number" min="0" @bind="weeklyRequirements.Sunday" />
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Available start times</h2>
                <p class="text-muted">Add or remove start-time slots that will appear as options in the staff add form.</p>
                @if (weeklyStartTimes.StartTimes.Any())
                {
                    @foreach (var (time, index) in weeklyStartTimes.StartTimes.Select((t, i) => (t, i)))
                    {
                        <div class="input-group mb-2">
                            <input type="time" class="form-control" @bind="weeklyStartTimes.StartTimes[index]" />
                            <button class="btn btn-outline-danger" type="button" @onclick="@(() => RemoveStartTime(index))">Remove</button>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No start times added yet.</p>
                }
                <button class="btn btn-secondary" @onclick="AddStartTime">Add start time</button>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Daily opening times</h2>
                <p class="text-muted">Set the opening time for each day of the week. (These are opening-up times, not necessarily times you open to the public)</p>
                @foreach (var day in new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" })
                {
                    <div class="mb-2">
                        <label class="form-label" for="opentime_@day">@day</label>
                        <input id="opentime_@day" type="time" class="form-control" @bind="dailyOpeningTimes.StartTimesByDay[day]" />
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Staff needed by a set time</h2>
                <p class="text-muted">Set the minimum number of people who must be in by a certain time. The rota will bring starts forward if needed.</p>
                @foreach (var day in new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" })
                {
                    <div class="row g-2 align-items-end mb-2">
                        <div class="col-sm-4">
                            <label class="form-label fw-semibold">@day</label>
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">People in by</label>
                            <input type="number" min="0" class="form-control" @bind="dailyCoverageTargets.CoverageByDay[day].RequiredStaff" />
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">Time</label>
                            <input type="time" class="form-control" @bind="dailyCoverageTargets.CoverageByDay[day].RequiredByTime" />
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Rota failsafes</h2>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="managerFirst" @bind="rotaGenerationOptions.AlwaysScheduleManagerFirst" />
                    <label class="form-check-label" for="managerFirst">Always schedule a manager on first</label>
                </div>
                <p class="text-muted mb-0">When enabled, each staffed day will start with a manager wherever one is available.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Available end times</h2>
                <p class="text-muted">Add or remove end-time slots that will appear as options in the staff add form.</p>
                @if (weeklyEndTimes.EndTimes.Any())
                {
                    @foreach (var (time, index) in weeklyEndTimes.EndTimes.Select((t, i) => (t, i)))
                    {
                        <div class="input-group mb-2">
                            <input type="time" class="form-control" @bind="weeklyEndTimes.EndTimes[index]" />
                            <button class="btn btn-outline-danger" type="button" @onclick="@(() => RemoveEndTime(index))">Remove</button>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No end times added yet.</p>
                }
                <button class="btn btn-secondary" @onclick="AddEndTime">Add end time</button>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Available job roles</h2>
                <p class="text-muted">Add or remove job roles that staff members can be assigned to.</p>
                @if (weeklyJobRoles.JobRoles.Any())
                {
                    @foreach (var (role, index) in weeklyJobRoles.JobRoles.Select((r, i) => (r, i)))
                    {
                        <div class="input-group mb-2">
                            <input type="text" class="form-control" placeholder="Job Role" @bind="weeklyJobRoles.JobRoles[index]" />
                            <button class="btn btn-outline-danger" type="button" @onclick="@(() => RemoveJobRole(index))">Remove</button>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No job roles added yet.</p>
                }
                <button class="btn btn-secondary" @onclick="AddJobRole">Add job role</button>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2>Daily job role requirements</h2>
                <p class="text-muted">Select which job roles are required for each day of the week.</p>
                @foreach (var day in new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" })
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold d-block">@day</label>
                        @if (weeklyJobRoles.JobRoles.Any())
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="@($"allroles_{day}")" checked="@AreAllJobRolesSelected(day)" @onchange="@(e => ToggleAllDayJobRoles(e, day))" />
                                <label class="form-check-label fw-semibold" for="@($"allroles_{day}")">All job roles required</label>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var role in weeklyJobRoles.JobRoles)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="@($"dayrole_{day}_{role}")" checked="@dailyJobRoles.JobRolesByDay[day].Contains(role)" @onchange="@(e => ToggleDayJobRole(e, day, role))" />
                                        <label class="form-check-label" for="@($"dayrole_{day}_{role}")">@role</label>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small">No job roles configured yet.</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<button class="btn btn-primary" @onclick="SaveWeeklyPrefs">Save preferences</button>
@if (!string.IsNullOrWhiteSpace(saveMessage))
{
    <div class="alert alert-success mt-3" role="alert">@saveMessage</div>
}

@code {
    private DayRequirements weeklyRequirements = new DayRequirements
    {
        Monday = 0,
        Tuesday = 0,
        Wednesday = 0,
        Thursday = 0,
        Friday = 0,
        Saturday = 0,
        Sunday = 0
    };
    private StartTimeRequirements weeklyStartTimes = new StartTimeRequirements();
    private EndTimeRequirements weeklyEndTimes = new EndTimeRequirements();
    private JobRoleRequirements weeklyJobRoles = new JobRoleRequirements();
    private DaySpecificStartTimes dailyOpeningTimes = new DaySpecificStartTimes();
    private DaySpecificCoverageRequirements dailyCoverageTargets = new DaySpecificCoverageRequirements();
    private RotaGenerationOptions rotaGenerationOptions = new RotaGenerationOptions();
    private DaySpecificJobRoles dailyJobRoles = new DaySpecificJobRoles();
    private string saveMessage = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedDayRequirements = await localStorage.GetItemAsync<DayRequirements>("weeklyDayRequirements");
            if (savedDayRequirements != null)
            {
                weeklyRequirements = savedDayRequirements;
            }

            var savedStartTimes = await localStorage.GetItemAsync<StartTimeRequirements>("startTimeRequirements");
            if (savedStartTimes != null)
            {
                weeklyStartTimes = savedStartTimes;
            }

            var savedEndTimes = await localStorage.GetItemAsync<EndTimeRequirements>("endTimeRequirements");
            if (savedEndTimes != null)            
            {
                weeklyEndTimes = savedEndTimes;
            }

            var savedJobRoles = await localStorage.GetItemAsync<JobRoleRequirements>("jobRoleRequirements");
            if (savedJobRoles != null)
            {
                weeklyJobRoles = savedJobRoles;
            }

            var savedDailyOpeningTimes = await localStorage.GetItemAsync<DaySpecificStartTimes>("daySpecificStartTimes");
            if (savedDailyOpeningTimes != null)
            {
                dailyOpeningTimes = savedDailyOpeningTimes;
            }

            var savedDailyCoverageTargets = await localStorage.GetItemAsync<DaySpecificCoverageRequirements>("daySpecificCoverageRequirements");
            if (savedDailyCoverageTargets != null)
            {
                dailyCoverageTargets = savedDailyCoverageTargets;
            }

            var savedRotaGenerationOptions = await localStorage.GetItemAsync<RotaGenerationOptions>("rotaGenerationOptions");
            if (savedRotaGenerationOptions != null)
            {
                rotaGenerationOptions = savedRotaGenerationOptions;
            }

            var savedDailyJobRoles = await localStorage.GetItemAsync<DaySpecificJobRoles>("daySpecificJobRoles");
            if (savedDailyJobRoles != null)
            {
                dailyJobRoles = savedDailyJobRoles;
            }

            StateHasChanged();
        }
    }

    async Task SaveWeeklyPrefs()
    {
        await localStorage.SetItemAsync("weeklyDayRequirements", weeklyRequirements);
        await localStorage.SetItemAsync("startTimeRequirements", weeklyStartTimes);
        await localStorage.SetItemAsync("endTimeRequirements", weeklyEndTimes);
        await localStorage.SetItemAsync("jobRoleRequirements", weeklyJobRoles);
        await localStorage.SetItemAsync("daySpecificStartTimes", dailyOpeningTimes);
        await localStorage.SetItemAsync("daySpecificCoverageRequirements", dailyCoverageTargets);
        await localStorage.SetItemAsync("rotaGenerationOptions", rotaGenerationOptions);
        await localStorage.SetItemAsync("daySpecificJobRoles", dailyJobRoles);
        saveMessage = "Weekly preferences saved locally.";
    }

    void AddStartTime()
    {
        weeklyStartTimes.StartTimes.Add(new TimeOnly(9, 0));
    }

    void AddEndTime()
    {
        weeklyEndTimes.EndTimes.Add(new TimeOnly(17, 0));
    }

    void AddJobRole()
    {
        weeklyJobRoles.JobRoles.Add("New Role");
    }

    void RemoveStartTime(int index)
    {
        if (index >= 0 && index < weeklyStartTimes.StartTimes.Count)
        {
            weeklyStartTimes.StartTimes.RemoveAt(index);
        }
    }

    void RemoveEndTime(int index)
    {
        if (index >= 0 && index < weeklyEndTimes.EndTimes.Count)
        {
            weeklyEndTimes.EndTimes.RemoveAt(index);
        }
    }

    void RemoveJobRole(int index)
    {
        if (index >= 0 && index < weeklyJobRoles.JobRoles.Count)
        {
            weeklyJobRoles.JobRoles.RemoveAt(index);
        }
    }

    void ToggleDayJobRole(ChangeEventArgs e, string day, string role)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        if (isChecked)
        {
            if (!dailyJobRoles.JobRolesByDay[day].Contains(role))
            {
                dailyJobRoles.JobRolesByDay[day].Add(role);
            }
        }
        else
        {
            dailyJobRoles.JobRolesByDay[day].Remove(role);
        }
    }

    void ToggleAllDayJobRoles(ChangeEventArgs e, string day)
    {
        var isChecked = e?.Value is bool boolValue && boolValue
            || e?.Value is string stringValue && (stringValue == "true" || stringValue == "on");

        dailyJobRoles.JobRolesByDay[day].Clear();

        if (isChecked)
        {
            dailyJobRoles.JobRolesByDay[day].AddRange(weeklyJobRoles.JobRoles.Distinct());
        }
    }

    bool AreAllJobRolesSelected(string day)
    {
        return weeklyJobRoles.JobRoles.Any()
            && weeklyJobRoles.JobRoles.All(role => dailyJobRoles.JobRolesByDay[day].Contains(role));
    }

    private static string FormatTime(TimeOnly? time)
    {
        return time.HasValue ? time.Value.ToString("HH:mm") : "Unset";
    }
}
