<LoggingErrorBoundary>
    <ChildContent>
        <Routes />
    </ChildContent>
    <ErrorContent Context="ex">
        <div class="alert alert-danger m-4" role="alert">
            <h2>Desktop app startup error</h2>
            <p><strong>@ex.Message</strong></p>
            <pre style="white-space: pre-wrap;">@ex.ToString()</pre>
        </div>
    </ErrorContent>
</LoggingErrorBoundary>

